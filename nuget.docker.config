<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Config NuGet dédiée aux conteneurs Linux (docker compose). Identique à nuget.config MAIS
    SANS la source offline « Microsoft Visual Studio Offline Packages » (chemin Windows
    C:\Program Files (x86)\… qui n'existe pas dans une image dotnet Linux et ferait échouer
    la restauration). Les services api/web la passent via `dotnet restore --configfile`.
    On ne tire que de nuget.org.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
