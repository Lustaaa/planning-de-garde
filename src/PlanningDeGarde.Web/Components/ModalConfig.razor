@* Composant modal COMMUN de la Config foyer (factorisation, finition PO s33) : backdrop + panneau, et
   fermeture à la touche Échap STRICTEMENT équivalente à « Annuler » — ferme sans muter, aucune commande
   émise (la fermeture est déléguée au parent via OnFermer, qui n'émet rien). Le contenu (formulaire,
   actions, motif de refus…) est passé tel quel en ChildContent — le DOM rendu reste identique à l'inline
   d'origine (mêmes classes .dialog-backdrop/.dialog-panneau et même data-testid), les acceptations existantes
   continuent de le cibler. La frappe Échap est captée sur le backdrop (@onkeydown) ; au montage, le backdrop
   prend le focus clavier (FocusAsync, best-effort) afin que la frappe l'atteigne dans un vrai navigateur. *@
<div class="dialog-backdrop" data-testid="@TestId" tabindex="-1" @ref="_backdrop" @onkeydown="SurTouche">
    <div class="dialog-panneau">
        @ChildContent
    </div>
</div>

@code {
    /// <summary>Identifiant de test du backdrop (ex. « dialog-acteur ») — préserve les sélecteurs des acceptations.</summary>
    [Parameter, EditorRequired] public string TestId { get; set; } = "";

    /// <summary>Action de fermeture « Annuler » du parent : elle ne fait QUE fermer (aucune commande émise).</summary>
    [Parameter] public EventCallback OnFermer { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    private ElementReference _backdrop;

    /// <summary>Échap = « Annuler » : ferme sans muter. Toute autre touche est ignorée — jamais « Enregistrer ».</summary>
    private async Task SurTouche(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            await OnFermer.InvokeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        try
        {
            // Focus clavier sur le backdrop pour qu'Échap l'atteigne dans un vrai navigateur. Best-effort :
            // sans JS (tests headless), l'appel est avalé — la frappe y est alors routée directement.
            await _backdrop.FocusAsync();
        }
        catch
        {
            // Focus indisponible (pas de JS) : sans incidence, la fermeture Échap reste câblée sur @onkeydown.
        }
    }
}
