@inject HttpClient Canal

@* Dialog (modal) « Éditer une période » ouverte depuis le menu d'actions d'une case (palier 7, écriture
   en contexte — 5ᵉ usage du menu clic-case). À l'ouverture elle LIT les périodes couvrant la date via le
   canal de lecture HTTP (GET /api/periodes/…) ainsi que les acteurs du foyer (GET /api/foyer/acteurs)
   pour alimenter le sélecteur. « Éditer » une ligne ouvre un formulaire PRÉ-REMPLI (responsable courant +
   bornes) ; « Enregistrer » émet la commande via le canal d'écriture HTTP (PUT /api/periodes/{id})
   — JAMAIS un handler en DI direct ni le canal de diffusion. Aucune règle métier ici. La clé envoyée est
   l'identifiant stable de la période. Issues : succès → OnValide (le parent ferme, accuse et relit la
   grille) ; refus métier / API injoignable → message DANS la dialog, la dialog reste ouverte. *@
<div class="dialog-backdrop" data-testid="dialog-editer-periode">
    <div class="dialog-panneau">
        <h2 class="h4 mb-3">Éditer une période — @DateContexte.ToString("dd/MM/yyyy")</h2>

        @if (_periodes is null)
        {
            <p class="text-muted" data-testid="periodes-chargement">Chargement des périodes…</p>
        }
        else if (_periodes.Count == 0)
        {
            <p class="text-muted" data-testid="periodes-vide">Aucune période ne couvre ce jour.</p>
        }
        else
        {
            <ul class="list-group mb-3">
                @foreach (var periode in _periodes)
                {
                    <li class="list-group-item" data-testid="periode-editable" data-periode-id="@periode.Id">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>
                                <strong>@periode.ResponsableNom</strong>
                                <span class="text-muted ms-2">@periode.Debut.ToString("dd/MM")–@periode.Fin.ToString("dd/MM")</span>
                            </span>
                            <button type="button" class="btn btn-sm btn-outline-primary" data-testid="bouton-editer-periode"
                                    @onclick="@(() => Editer(periode))">Éditer</button>
                        </div>

                        @if (_enEdition is { } enEdition && enEdition.Id == periode.Id)
                        {
                            <div class="mt-3" data-testid="formulaire-edition">
                                <div class="mb-2">
                                    <label class="form-label">Responsable</label>
                                    <select class="form-select" data-testid="champ-responsable-edition" @bind="_form.ResponsableId">
                                        @foreach (var acteur in _acteurs)
                                        {
                                            <option value="@acteur.Id">@acteur.Nom</option>
                                        }
                                    </select>
                                </div>
                                <div class="row">
                                    <div class="col mb-2">
                                        <label class="form-label">Début</label>
                                        <input type="date" class="form-control" data-testid="champ-debut-edition"
                                               @bind="_form.Debut" @bind:format="yyyy-MM-dd" />
                                    </div>
                                    <div class="col mb-2">
                                        <label class="form-label">Fin</label>
                                        <input type="date" class="form-control" data-testid="champ-fin-edition"
                                               @bind="_form.Fin" @bind:format="yyyy-MM-dd" />
                                    </div>
                                </div>
                                <button type="button" class="btn btn-primary" data-testid="bouton-enregistrer-edition"
                                        @onclick="Enregistrer">Enregistrer</button>
                            </div>
                        }
                    </li>
                }
            </ul>
        }

        <div class="dialog-actions">
            <button type="button" class="btn btn-link" data-testid="dialog-annuler" @onclick="Annuler">Fermer</button>
        </div>

        @if (_motifEchec is not null)
        {
            <div class="alert alert-danger mt-3" data-testid="motif-echec">@_motifEchec</div>
        }
    </div>
</div>
