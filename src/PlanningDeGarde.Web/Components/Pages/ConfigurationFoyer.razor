@page "/configuration"
@using System.Linq
@implements IAsyncDisposable
@inject HttpClient Canal
@inject PlanningDeGarde.Web.State.SessionPlanning Session
@using static PlanningDeGarde.Web.CanalEcriture

<PageTitle>Configuration du foyer</PageTitle>

@* Configuration du foyer façon « settings » : barre latérale gauche (Acteurs / Rôles / Cycles) +
   panneau de contenu resserré (.pdg-etroite). Les trois panneaux restent TOUJOURS rendus (masqués
   par CSS quand inactifs) : le gating d'écriture (identité effective) demeure DANS chaque panneau,
   la navigation par onglet n'est que de la présentation. *@
<div class="pdg-etroite">

    <div class="config-entete">
        <h1 class="config-titre">Configuration du foyer</h1>
        <p class="config-sous">Acteurs, rôles et cycle de responsabilité par défaut du foyer.</p>
    </div>

    @* Bandeau d'incarnation (global, hors onglets) : sous incarnation, « Vous incarnez X » + retour —
       explique pourquoi les écritures sont masquées (gating identité effective, Sc.7). *@
    @if (Session.LibelleBandeau is { } libelleBandeau)
    {
        <div class="alert alert-secondary d-flex justify-content-between align-items-center py-2"
             data-testid="bandeau-incarnation" role="status">
            <span>@libelleBandeau</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" data-testid="revenir-identite-reelle"
                    @onclick="RevenirIdentiteReelle">Revenir à mon identité</button>
        </div>
    }

    <div class="config-layout">
        <nav class="config-nav" aria-label="Sections de configuration">
            <button type="button" class="config-nav-item @(_onglet == "acteurs" ? "actif" : null)"
                    data-testid="onglet-acteurs" @onclick='() => ChoisirOnglet("acteurs")'>
                <span class="config-nav-ic" aria-hidden="true">👤</span>Acteurs
            </button>
            <button type="button" class="config-nav-item @(_onglet == "roles" ? "actif" : null)"
                    data-testid="onglet-roles" @onclick='() => ChoisirOnglet("roles")'>
                <span class="config-nav-ic" aria-hidden="true">🏷️</span>Rôles
            </button>
            <button type="button" class="config-nav-item @(_onglet == "cycles" ? "actif" : null)"
                    data-testid="onglet-cycles" @onclick='() => ChoisirOnglet("cycles")'>
                <span class="config-nav-ic" aria-hidden="true">🔁</span>Cycles
            </button>
            <button type="button" class="config-nav-item @(_onglet == "lieux" ? "actif" : null)"
                    data-testid="onglet-lieux" @onclick='() => ChoisirOnglet("lieux")'>
                <span class="config-nav-ic" aria-hidden="true">📍</span>Lieux
            </button>
            <button type="button" class="config-nav-item @(_onglet == "enfants" ? "actif" : null)"
                    data-testid="onglet-enfants" @onclick='() => ChoisirOnglet("enfants")'>
                <span class="config-nav-ic" aria-hidden="true">🧒</span>Enfants
            </button>
        </nav>

        <div class="config-panneaux">

            @* ══════════════ Panneau ACTEURS ══════════════ *@
            <section class="config-panneau @(_onglet == "acteurs" ? null : "cacher")"
                     data-testid="panneau-acteurs" aria-label="Acteurs">

                @* Refonte s32 (patron « tableau lecture seule + crayon → modal », brief refonte-config) :
                   la table des acteurs est PUREMENT EN LECTURE (pastille + nom, email + statut du compte,
                   rôle, état actif/admin en pastille/badge). Toute l'ÉCRITURE d'un acteur — nom, couleur,
                   rôle, compte, admin, suppression — est déportée dans la MODAL ouverte par le crayon de la
                   ligne (édition) ou par le bouton « Ajouter un acteur » (création). Réutilise les MÊMES
                   commandes CRUD (aucun handler neuf) et les mêmes testids d'écriture. Gating d'écriture sur
                   l'identité EFFECTIVE (règle 9) : crayon, bouton d'ajout et modal ne sont rendus que Parent. *@

                @if (_accuseSuppression is not null)
                {
                    <div class="alert alert-warning" role="status" data-testid="accuse-suppression">@_accuseSuppression</div>
                }
                @if (_accuseActivation is not null)
                {
                    <div class="alert alert-success" role="status" data-testid="accuse-activation">@_accuseActivation</div>
                }
                @if (_motifEchecSuppression is not null)
                {
                    <div class="alert alert-danger" data-testid="motif-echec-suppression">@_motifEchecSuppression</div>
                }

                <div class="acteurs-defilement">
                    <table class="acteurs-table" data-testid="liste-acteurs">
                        <thead>
                            <tr>
                                <th>Acteur</th>
                                <th>Rôle</th>
                                <th>Compte</th>
                                <th>État</th>
                                @if (Session.EstParent)
                                {
                                    <th class="acteurs-col-actions">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _acteurs)
                            {
                                <tr class="acteur-ligne" data-testid="acteur-foyer"
                                    data-acteur-id="@a.Id" data-couleur="@a.Couleur">
                                    <td>
                                        <span class="acteur-cell">
                                            <span class="acteur-pastille" style="background-color:@CouleursTheme.Pleine(a.Couleur);"
                                                  aria-hidden="true"></span>
                                            <span class="acteur-nom">@a.Nom</span>
                                        </span>
                                        @* Adresse de résidence (Sc.5) en LECTURE : ligne dédiée sous le nom, rendue seulement
                                           si renseignée (champ optionnel — absente = rien à afficher). *@
                                        @if (!string.IsNullOrEmpty(a.Adresse))
                                        {
                                            <div class="acteur-adresse" data-testid="acteur-adresse">@a.Adresse</div>
                                        }
                                    </td>
                                    <td>
                                        @* Rôle courant (lecture pour tous) : libellé résolu sur l'id stable du référentiel. *@
                                        <div class="acteur-role" data-testid="role-acteur-courant">@LibelleRoleActeur(a.RoleId)</div>
                                    </td>
                                    <td>
                                        @* Compte associé (LECTURE pour tous) : email + statut, s'il en porte un. La création /
                                           l'activation se font dans la modal (crayon), pas ici. *@
                                        @if (CompteDe(a.Id) is { } compte)
                                        {
                                            <span class="acteur-compte" data-testid="compte-acteur">
                                                @compte.Email — <span class="acteur-compte-statut">@compte.Statut</span>
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @* État actif/admin matérialisé en pastille/badge de LECTURE (pour tous). *@
                                        @if (CompteDe(a.Id) is { } c)
                                        {
                                            <span class="badge @(EstInactif(c) ? "bg-light text-dark" : "bg-success") acteur-etat-compte"
                                                  data-testid="acteur-etat-compte">@(EstInactif(c) ? "inactif" : "actif")</span>
                                        }
                                        @if (EstAdmin(a.Id))
                                        {
                                            <span class="badge bg-secondary acteur-admin" data-testid="acteur-admin-marqueur">admin</span>
                                        }
                                    </td>
                                    @if (Session.EstParent)
                                    {
                                        <td class="acteurs-col-actions">
                                            @* Crayon d'édition : ouvre la modal pré-remplie sur cet acteur (id stable porté). *@
                                            <button type="button" class="btn btn-outline-secondary btn-sm acteur-crayon"
                                                    data-testid="crayon-acteur" data-acteur-id="@a.Id"
                                                    @onclick="() => OuvrirEdition(a.Id)" aria-label="Modifier @a.Nom">✏️</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Session.EstParent)
                {
                    @* Bouton d'ajout au bas du tableau : ouvre la MÊME modal, champs vides (mode création). *@
                    <div class="acteurs-ajout">
                        <button type="button" class="btn btn-primary" data-testid="bouton-ajouter-acteur"
                                @onclick="OuvrirAjout">Ajouter un acteur</button>
                    </div>

                    @* ── MODAL acteur (édition OU ajout) ── rendue seulement quand ouverte et sous identité Parent.
                       Réutilise les commandes CRUD existantes et les testids d'écriture (champ-nom, champ-couleur,
                       selecteur-role-acteur, compte, admin, suppression). *@
                    @if (_modalAjout || _modalActeurId is not null)
                    {
                        var acteurEdite = _modalActeurId is null ? null : _acteurs.FirstOrDefault(x => x.Id == _modalActeurId);
                        <div class="dialog-backdrop" data-testid="dialog-acteur">
                            <div class="dialog-panneau">
                                <h2 class="h4 mb-3">@(_modalAjout ? "Ajouter un acteur" : "Modifier l'acteur")</h2>

                                @if (_modalAjout)
                                {
                                    @* Mode CRÉATION : champs vides, identifiant stable neuf posé côté handler. *@
                                    <EditForm Model="_ajout" OnValidSubmit="Ajouter" FormName="ajouter-acteur" id="form-ajout">
                                        <div class="mb-3">
                                            <label class="form-label">Nom</label>
                                            <InputText class="form-control" @bind-Value="_ajout.Nom" data-testid="champ-nom-ajout"
                                                       placeholder="Nom du nouvel acteur" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Couleur</label>
                                            <InputSelect class="form-select" @bind-Value="_ajout.Couleur" data-testid="champ-couleur-ajout">
                                                <option value="">— neutre —</option>
                                                <option value="rose">Rose</option>
                                                <option value="bleu">Bleu</option>
                                                <option value="orange">Orange</option>
                                                <option value="vert">Vert</option>
                                                <option value="violet">Violet</option>
                                            </InputSelect>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                                            <button type="button" class="btn btn-link" data-testid="dialog-acteur-annuler"
                                                    @onclick="FermerModal">Annuler</button>
                                        </div>
                                    </EditForm>
                                    @if (_motifEchecAjout is not null)
                                    {
                                        <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec-ajout">@_motifEchecAjout</div>
                                    }
                                }
                                else if (acteurEdite is { } a)
                                {
                                    @* Mode ÉDITION : pré-rempli sur les champs courants ; l'id stable est porté par la modal
                                       (data-acteur-id), jamais éditable ni dérivé du libellé. *@
                                    <div data-testid="dialog-acteur-id" data-acteur-id="@a.Id"></div>

                                    <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="editer-acteur" id="form-edition">
                                        <div class="mb-3">
                                            <label class="form-label">Nom</label>
                                            <InputText class="form-control" @bind-Value="_form.Nom" data-testid="champ-nom"
                                                       placeholder="Nom de l'acteur" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Couleur</label>
                                            <InputSelect class="form-select" @bind-Value="_form.Couleur" data-testid="champ-couleur">
                                                <option value="">— inchangée —</option>
                                                <option value="bleu">Bleu</option>
                                                <option value="orange">Orange</option>
                                                <option value="vert">Vert</option>
                                                <option value="violet">Violet</option>
                                            </InputSelect>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Adresse de résidence</label>
                                            @* Champ ADRESSE (Sc.5) : pré-rempli sur la valeur courante, éditable. Optionnel —
                                               une adresse vide est acceptée (Sc.1) et n'écrase pas les autres champs. *@
                                            <InputText class="form-control" @bind-Value="_form.Adresse" data-testid="champ-adresse"
                                                       placeholder="Adresse de résidence (optionnelle)" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Rôle</label>
                                            @* Sélecteur BORNÉ AU RÉFÉRENTIEL : exactement les rôles du foyer + « sans rôle ».
                                               La valeur bindée est l'id de rôle (jamais le libellé) ; vide = retrait. Appliqué
                                               immédiatement (commande existante affecter/retirer-role). *@
                                            <select class="form-select acteur-selecteur-role" data-testid="selecteur-role-acteur"
                                                    value="@(a.RoleId ?? "")"
                                                    @onchange="e => AffecterRole(a.Id, e.Value?.ToString())">
                                                <option value="">sans rôle</option>
                                                @foreach (var r in _roles)
                                                {
                                                    <option value="@r.Id">@r.Libelle</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                                            <button type="button" class="btn btn-link" data-testid="dialog-acteur-annuler"
                                                    @onclick="FermerModal">Annuler</button>
                                        </div>
                                    </EditForm>
                                    @if (_motifEchec is not null)
                                    {
                                        <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec">@_motifEchec</div>
                                    }

                                    <hr />

                                    @* Compte associé : compte existant (statut + activer), ou mini-formulaire de création
                                       (email obligatoire). Écriture via le canal HTTP ; sur refus, le motif reste dans la
                                       modal, sans compte créé. *@
                                    <div class="mb-3">
                                        <label class="form-label">Compte</label>
                                        @if (CompteDe(a.Id) is { } compte)
                                        {
                                            <div>
                                                <span class="acteur-compte" data-testid="compte-acteur-modal">
                                                    @compte.Email — <span class="acteur-compte-statut">@compte.Statut</span>
                                                </span>
                                            </div>
                                            @* Toggle ACTIF (Sc.4) — sens ON : actionnable seulement si le compte est INACTIF ;
                                               verrouillé (disabled) si déjà actif (désactivation absente du domaine ce sprint).
                                               Appliqué à l'« Enregistrer » via la commande existante activer-compte. *@
                                            <div class="form-check form-switch mt-2">
                                                <input type="checkbox" class="form-check-input acteur-toggle-actif" role="switch"
                                                       id="toggle-actif-@a.Id" data-testid="toggle-actif" @bind="_form.Actif"
                                                       disabled="@(!EstInactif(compte))" />
                                                <label class="form-check-label" for="toggle-actif-@a.Id">Compte actif</label>
                                            </div>
                                            @if (!EstInactif(compte))
                                            {
                                                <div class="text-muted small mt-1" data-testid="toggle-actif-motif">
                                                    Compte déjà actif (le retrait de l'activation arrivera dans un prochain incrément).</div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="acteur-compte-form">
                                                <input type="email" class="form-control acteur-champ-email"
                                                       data-testid="champ-email-compte" placeholder="email du compte"
                                                       @bind:get="EmailCompte(a.Id)" @bind:set="v => SaisirEmailCompte(a.Id, v)"
                                                       @bind:event="onchange" />
                                                <button type="button" class="btn btn-outline-primary btn-sm mt-2"
                                                        data-testid="bouton-creer-compte"
                                                        @onclick="() => CreerCompte(a.Id)">Créer le compte</button>
                                            </div>
                                            @if (MotifEchecCompte(a.Id) is { } motifCompte)
                                            {
                                                <div class="alert alert-danger py-1 px-2 mb-0 mt-2 acteur-compte-motif"
                                                     data-testid="motif-echec-compte">@motifCompte</div>
                                            }
                                            @* Toggle ACTIF désactivé : sans compte associé, rien à activer (motif dedans). *@
                                            <div class="form-check form-switch mt-2">
                                                <input type="checkbox" class="form-check-input acteur-toggle-actif" role="switch"
                                                       data-testid="toggle-actif" @bind="_form.Actif" disabled />
                                                <label class="form-check-label">Compte actif</label>
                                            </div>
                                            <div class="text-muted small mt-1" data-testid="toggle-actif-motif">
                                                Créez d'abord un compte pour pouvoir l'activer.</div>
                                        }
                                    </div>

                                    @* État ADMIN (Sc.4) — toggle sens ON : verrouillé (disabled) si l'acteur est DÉJÀ admin
                                       (la dé-désignation est absente du domaine ce sprint, reportée backlog). Appliqué à
                                       l'« Enregistrer » via la commande existante designer-admin. *@
                                    <div class="mb-3">
                                        <label class="form-label">Admin</label>
                                        <div class="form-check form-switch">
                                            <input type="checkbox" class="form-check-input acteur-toggle-admin" role="switch"
                                                   id="toggle-admin-@a.Id" data-testid="toggle-admin" @bind="_form.Admin"
                                                   disabled="@EstAdmin(a.Id)" />
                                            <label class="form-check-label" for="toggle-admin-@a.Id">Administrateur du foyer</label>
                                        </div>
                                        @if (EstAdmin(a.Id))
                                        {
                                            <div class="text-muted small mt-1" data-testid="toggle-admin-motif">
                                                Déjà administrateur (le retrait arrivera dans un prochain incrément).</div>
                                        }
                                    </div>

                                    <hr />

                                    @* Suppression de l'acteur (commande existante) : sur succès, ferme la modal et retire
                                       l'acteur de la table (cases orphelines → fond/neutre, sans nom fantôme). *@
                                    <button type="button" class="btn btn-outline-danger btn-sm acteur-supprimer"
                                            data-testid="bouton-supprimer" data-acteur-id="@a.Id"
                                            @onclick="() => Supprimer(a.Id)" aria-label="Supprimer @a.Nom">Supprimer cet acteur</button>
                                }
                            </div>
                        </div>
                    }
                }
            </section>

            @* ══════════════ Panneau RÔLES ══════════════ *@
            <section class="config-panneau @(_onglet == "roles" ? null : "cacher")"
                     data-testid="panneau-roles" aria-label="Rôles">
                @* Référentiel de rôles (Sc.7) : créer / renommer / supprimer. La valeur d'un rôle affectable à
                   un acteur provient EXCLUSIVEMENT de ce référentiel (jamais un libellé en dur). Écritures via
                   le canal HTTP (POST /api/canal/{creer,renommer,supprimer}-role). Gating Parent. *@
                @if (Session.EstParent)
                {
                    <h2 class="config-panneau-titre">Rôles du foyer</h2>
                    <p class="text-muted">Gérer le référentiel de rôles (Nounou, Grand-parent…). Un rôle reçoit un
                        identifiant stable neuf (jamais dérivé du libellé) ; il peut ensuite être affecté à un acteur.
                        Créer, renommer ou supprimer un rôle met la liste à jour sans recharger la page.</p>

                    <EditForm Model="_role" OnValidSubmit="CreerRole" FormName="creer-role" id="form-creer-role">
                        <div class="input-group mb-3">
                            <InputText class="form-control" @bind-Value="_role.Libelle" data-testid="champ-libelle-role"
                                       placeholder="Libellé du rôle (ex. Nounou)" />
                            <button type="submit" class="btn btn-primary">Créer le rôle</button>
                        </div>
                    </EditForm>

                    @if (_motifEchecRole is not null)
                    {
                        <div class="alert alert-danger mb-3" data-testid="motif-echec-role">@_motifEchecRole</div>
                    }

                    <ul class="list-group" data-testid="liste-roles">
                        @foreach (var r in _roles)
                        {
                            <li class="list-group-item role-ligne" data-testid="role-foyer" data-role-id="@r.Id">
                                <span class="role-libelle">@r.Libelle</span>
                                <span class="role-actions">
                                    <input type="text" class="form-control form-control-sm role-champ-renommer"
                                           data-testid="champ-renommer-role"
                                           @bind:get="LibelleRenommage(r.Id, r.Libelle)"
                                           @bind:set="v => SaisirRenommage(r.Id, v)" @bind:event="onchange" />
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            data-testid="bouton-renommer-role"
                                            @onclick="() => RenommerRole(r.Id)">Renommer</button>
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            data-testid="bouton-supprimer-role"
                                            @onclick="() => SupprimerRole(r.Id)" aria-label="Supprimer @r.Libelle">Supprimer</button>
                                </span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">La gestion des rôles est réservée aux parents du foyer.</p>
                }
            </section>

            @* ══════════════ Panneau CYCLES ══════════════ *@
            <section class="config-panneau @(_onglet == "cycles" ? null : "cacher")"
                     data-testid="panneau-periode-garde" aria-label="Cycle de fond">
                @* Cycle de fond (responsabilité par défaut) : écriture gardée sur l'identité effective (Sc.7). *@
                @if (Session.EstParent)
                {
                    <h2 class="config-panneau-titre">Cycle de fond (responsabilité par défaut)</h2>
                    <p class="text-muted">Définir le nombre de semaines du cycle et, pour chaque semaine (index ISO),
                        le responsable de fond. Les jours sans période explicite suivent ce cycle ; la grille se met à jour
                        sans recharger la page. Une nouvelle définition remplace le cycle courant.</p>

                    <EditForm Model="_cycle" OnValidSubmit="DefinirCycle" FormName="definir-cycle" id="form-cycle">
                        <div class="mb-3">
                            <label class="form-label">Nombre de semaines du cycle</label>
                            <InputNumber class="form-control" @bind-Value="_cycle.NombreSemaines"
                                         @bind-Value:after="StateHasChanged" data-testid="champ-nombre-semaines" min="1" />
                        </div>
                        <div class="cycle-semaines">
                            @for (var i = 0; i < _cycle.NombreSemaines && i < 12; i++)
                            {
                                var index = i;
                                <div class="cycle-carte">
                                    <label class="cycle-carte-label">Semaine d'index @index</label>
                                    <select class="form-select" data-testid="champ-cycle-index-@index"
                                            value="@(_cycle.Affectations.TryGetValue(index, out var r) ? r : "")"
                                            @onchange="e => AffecterIndex(index, e.Value?.ToString())">
                                        <option value="">— aucun (teinte neutre) —</option>
                                        @foreach (var a in _acteurs)
                                        {
                                            <option value="@a.Id">@a.Nom</option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>
                        <button type="submit" class="btn btn-primary mt-3">Définir le cycle</button>
                    </EditForm>

                    @if (_confirmationCycle is not null)
                    {
                        <div class="alert alert-success mt-3" data-testid="confirmation-cycle">@_confirmationCycle</div>
                    }
                    @if (_motifEchecCycle is not null)
                    {
                        <div class="alert alert-danger mt-3" data-testid="motif-echec-cycle">@_motifEchecCycle</div>
                    }
                }
                else
                {
                    <p class="text-muted">La définition du cycle de fond est réservée aux parents du foyer.</p>
                }
            </section>

            @* ══════════════ Panneau LIEUX ══════════════ *@
            <section class="config-panneau @(_onglet == "lieux" ? null : "cacher")"
                     data-testid="panneau-lieux" aria-label="Lieux">
                @* Référentiel de lieux du foyer (s27) : ajouter / supprimer. Les lieux disponibles à la saisie
                   (sélecteurs des dialogs Poser un slot / Définir un transfert) proviennent EXCLUSIVEMENT de ce
                   référentiel vivant (jamais un lieu en dur). Écritures via le canal HTTP
                   (POST /api/canal/{ajouter,supprimer}-lieu). Gating Parent. *@
                @if (Session.EstParent)
                {
                    <h2 class="config-panneau-titre">Lieux du foyer</h2>
                    <p class="text-muted">Gérer le référentiel de lieux (école, domicile, nounou, piscine…). Un lieu
                        ajouté devient aussitôt disponible à la saisie d'un slot ou d'un transfert ; un lieu supprimé
                        n'est plus proposé. La liste et les sélecteurs suivent sans recharger la page.</p>

                    <EditForm Model="_lieu" OnValidSubmit="AjouterLieu" FormName="ajouter-lieu" id="form-ajouter-lieu">
                        <div class="input-group mb-3">
                            <InputText class="form-control" @bind-Value="_lieu.Libelle" data-testid="champ-libelle-lieu"
                                       placeholder="Libellé du lieu (ex. piscine)" />
                            <button type="submit" class="btn btn-primary">Ajouter le lieu</button>
                        </div>
                    </EditForm>

                    @if (_motifEchecLieu is not null)
                    {
                        <div class="alert alert-danger mb-3" data-testid="motif-echec-lieu">@_motifEchecLieu</div>
                    }

                    <ul class="list-group" data-testid="liste-lieux">
                        @foreach (var l in _lieux)
                        {
                            <li class="list-group-item role-ligne" data-testid="lieu-foyer" data-lieu-id="@l.Id">
                                <span class="role-libelle">@l.Libelle</span>
                                <span class="role-actions">
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            data-testid="bouton-supprimer-lieu"
                                            @onclick="() => SupprimerLieu(l.Id)" aria-label="Supprimer @l.Libelle">Supprimer</button>
                                </span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">La gestion des lieux est réservée aux parents du foyer.</p>
                }
            </section>

            @* ══════════════ Panneau ENFANTS ══════════════ *@
            <section class="config-panneau @(_onglet == "enfants" ? null : "cacher")"
                     data-testid="panneau-enfants" aria-label="Enfants">
                @* Référentiel d'enfants du foyer (s30) : lister / ajouter / éditer. L'enfant est désormais un
                   agrégat de 1er rang, énuméré depuis ce référentiel vivant (jamais un enfant en dur / fantôme) ;
                   il alimente le sélecteur d'enfant de la dialog de pose (S10). Écritures via le canal HTTP
                   (POST /api/canal/{ajouter,editer}-enfant). Gating Parent. *@
                @if (Session.EstParent)
                {
                    <h2 class="config-panneau-titre">Enfants du foyer</h2>
                    <p class="text-muted">Gérer le référentiel d'enfants (Léa, Tom…). Un enfant ajouté reçoit un
                        identifiant stable neuf (jamais dérivé du prénom) et devient aussitôt sélectionnable à la
                        pose d'un slot ; éditer un prénom conserve l'identifiant. La liste suit sans recharger la page.</p>

                    <EditForm Model="_enfant" OnValidSubmit="AjouterEnfant" FormName="ajouter-enfant" id="form-ajouter-enfant">
                        <div class="input-group mb-3">
                            <InputText class="form-control" @bind-Value="_enfant.Prenom" data-testid="champ-prenom-enfant"
                                       placeholder="Prénom de l'enfant (ex. Tom)" />
                            <button type="submit" class="btn btn-primary">Ajouter l'enfant</button>
                        </div>
                    </EditForm>

                    @if (_motifEchecEnfant is not null)
                    {
                        <div class="alert alert-danger mb-3" data-testid="motif-echec-enfant">@_motifEchecEnfant</div>
                    }

                    <ul class="list-group" data-testid="liste-enfants">
                        @foreach (var e in _enfants)
                        {
                            <li class="list-group-item role-ligne" data-testid="enfant-foyer" data-enfant-id="@e.Id">
                                <span class="role-libelle">@e.Prenom</span>
                                <span class="role-actions">
                                    <input type="text" class="form-control form-control-sm role-champ-renommer"
                                           data-testid="champ-editer-enfant"
                                           @bind:get="PrenomEdition(e.Id, e.Prenom)"
                                           @bind:set="v => SaisirEditionEnfant(e.Id, v)" @bind:event="onchange" />
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            data-testid="bouton-editer-enfant"
                                            @onclick="() => EditerEnfant(e.Id)">Éditer</button>
                                </span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">La gestion des enfants est réservée aux parents du foyer.</p>
                }
            </section>

        </div>
    </div>
</div>

<style>
    /* Configuration « Studio » : mise en page façon settings (barre latérale gauche + panneau), tokenisée
       (clair ET sombre). Les pastilles de couleur d'acteur restent INLINE (donnée). */

    .config-entete { margin-bottom: 1.5rem; }
    .config-titre { font-size: 1.55rem; font-weight: 800; letter-spacing: -.025em; }
    .config-sous { color: var(--pdg-muted); font-size: .92rem; margin: .2rem 0 0; }

    /* Grille sidebar + panneau. La barre latérale colle sous la barre d'app. */
    .config-layout { display: grid; grid-template-columns: 220px 1fr; gap: 1.75rem; align-items: start; }
    .config-nav { display: flex; flex-direction: column; gap: 2px; position: sticky; top: 4.6rem; }
    .config-nav-item { display: flex; align-items: center; gap: .6rem; text-align: left; width: 100%;
        background: transparent; border: none; color: var(--pdg-ink); padding: .55rem .8rem;
        border-radius: 9px; font-weight: 600; font-size: .92rem; cursor: pointer; }
    .config-nav-item:hover { background: var(--pdg-surface-2); }
    .config-nav-item.actif { background: var(--pdg-accent-soft); color: var(--pdg-accent);
        box-shadow: inset 3px 0 0 var(--pdg-accent); }
    .config-nav-ic { width: 1.1rem; text-align: center; opacity: .85; }

    .config-panneau { background: var(--pdg-card); border: 1px solid var(--pdg-border); border-radius: 16px;
        padding: 1.35rem 1.5rem; box-shadow: 0 1px 2px rgba(16,24,40,.05); }
    .config-panneau-titre { font-size: 1.15rem; font-weight: 800; letter-spacing: -.01em; margin: 0 0 .4rem; }

    /* Formulaires ajout / modification en deux cartes compactes. */
    .config-formulaires { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1rem; margin-bottom: 1.25rem; }
    .config-carte { background: var(--pdg-surface-2); border: 1px solid var(--pdg-border); border-radius: 12px;
        padding: .9rem 1rem; }
    .config-carte-titre { font-size: .82rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
        color: var(--pdg-muted); margin: 0 0 .7rem; }
    .config-ligne-form { display: flex; gap: .5rem; flex-wrap: wrap; align-items: center; }
    .config-ligne-form .form-control, .config-ligne-form .form-select { flex: 1 1 8rem; min-width: 7rem; }

    /* Table des acteurs fusionnée. */
    .acteurs-defilement { overflow-x: auto; }
    .acteurs-table { width: 100%; border-collapse: collapse; }
    .acteurs-table th { text-align: left; font-size: .66rem; text-transform: uppercase; letter-spacing: .08em;
        color: var(--pdg-muted); font-weight: 700; padding: .6rem .7rem; border-bottom: 2px solid var(--pdg-border);
        white-space: nowrap; }
    .acteurs-table td { padding: .7rem; border-bottom: 1px solid var(--pdg-border); vertical-align: top; font-size: .9rem; }
    .acteurs-table tbody tr:last-child td { border-bottom: none; }
    .acteurs-table tbody tr:hover { background: var(--pdg-surface-2); }
    .acteurs-col-actions { text-align: right; white-space: nowrap; }
    .acteur-cell { display: inline-flex; align-items: center; gap: .55rem; }
    .acteur-pastille { width: 16px; height: 16px; border-radius: 5px; display: inline-block; flex: none;
        border: 1px solid rgba(0,0,0,.15); box-shadow: 0 1px 2px rgba(16,24,40,.10); }
    .acteur-nom { color: var(--pdg-ink); font-weight: 700; }
    .acteur-role { color: var(--pdg-muted); font-size: .82rem; margin-bottom: .35rem; }
    .acteur-adresse { color: var(--pdg-muted); font-size: .78rem; margin-top: .15rem; }
    .acteur-selecteur-role { max-width: 12rem; }
    .acteur-compte { font-size: .82rem; color: var(--pdg-muted); display: block; margin-bottom: .3rem; }
    .acteur-compte-statut { font-weight: 700; }
    .acteur-compte-form { display: flex; gap: .4rem; flex-wrap: wrap; align-items: center; }
    .acteur-admin { display: inline-block; margin-bottom: .35rem; }
    .acteur-designer-admin { display: inline-block; }
    .acteur-activer-compte { margin-left: .4rem; }
    .acteur-etat-compte { margin-right: .35rem; }
    .acteurs-ajout { margin-top: 1rem; display: flex; justify-content: flex-start; }
    .acteurs-col-actions .acteur-crayon { font-size: 1rem; line-height: 1; }

    /* Rôles (liste). */
    .role-ligne { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .role-libelle { color: var(--pdg-ink); font-weight: 700; }
    .role-actions { display: inline-flex; align-items: center; gap: .4rem; margin-left: auto; flex-wrap: wrap; }
    .role-champ-renommer { max-width: 12rem; }

    /* Cycle : grille de cartes-semaine. */
    .cycle-semaines { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: .7rem; }
    .cycle-carte { background: var(--pdg-surface-2); border: 1px solid var(--pdg-border); border-radius: 10px;
        padding: .7rem .85rem; }
    .cycle-carte-label { display: block; font-size: .7rem; text-transform: uppercase; letter-spacing: .05em;
        color: var(--pdg-muted); font-weight: 700; margin-bottom: .4rem; }

    .cacher { display: none; }

    @@media (max-width: 720px) {
        .config-layout { grid-template-columns: 1fr; }
        .config-nav { position: static; flex-direction: row; overflow-x: auto; }
    }
</style>
