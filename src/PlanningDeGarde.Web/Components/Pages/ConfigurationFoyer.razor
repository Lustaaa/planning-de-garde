@page "/configuration"
@using System.Linq
@implements IAsyncDisposable
@inject HttpClient Canal
@inject PlanningDeGarde.Web.State.SessionPlanning Session
@using static PlanningDeGarde.Web.CanalEcriture

<PageTitle>Configuration du foyer</PageTitle>

@* Configuration du foyer façon « settings » : barre latérale gauche (Acteurs / Rôles / Cycles) +
   panneau de contenu resserré (.pdg-etroite). Les trois panneaux restent TOUJOURS rendus (masqués
   par CSS quand inactifs) : le gating d'écriture (identité effective) demeure DANS chaque panneau,
   la navigation par onglet n'est que de la présentation. *@
<div class="pdg-etroite">

    <div class="config-entete">
        <h1 class="config-titre">Configuration du foyer</h1>
        <p class="config-sous">Acteurs, rôles et cycle de responsabilité par défaut du foyer.</p>
    </div>

    @* Bandeau d'incarnation (global, hors onglets) : sous incarnation, « Vous incarnez X » + retour —
       explique pourquoi les écritures sont masquées (gating identité effective, Sc.7). *@
    @if (Session.LibelleBandeau is { } libelleBandeau)
    {
        <div class="alert alert-secondary d-flex justify-content-between align-items-center py-2"
             data-testid="bandeau-incarnation" role="status">
            <span>@libelleBandeau</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" data-testid="revenir-identite-reelle"
                    @onclick="RevenirIdentiteReelle">Revenir à mon identité</button>
        </div>
    }

    @* ══════════════ Vue LECTURE SEULE « graphe enfant-racine » (s38) ══════════════
       Affichée À L'ARRIVÉE sur la Config foyer (briefing PO : « quand on arrive sur la configuration du
       foyer, une vue en lecture seule affichée comme un graph avec comme racine l'enfant ») : chaque enfant
       en RACINE, ses parents liés en branches « nom (rôle-du-lien) ». STRICTEMENT lecture — aucun contrôle
       d'édition, aucune commande émise d'ici (l'écriture reste dans la modal Enfants). Reflet fidèle du store
       (orphelins filtrés côté API, zéro fantôme) ; converge en temps réel via la diffusion SignalR lecture
       seule. Surface NEUVE de lecture (pas un swap) — Invité la voit aussi (lecture non gatée). *@
    <section class="config-graphe" data-testid="graphe-foyer" aria-label="Graphe du foyer (lecture seule)">
        <h2 class="config-graphe-titre">Foyer</h2>
        @if (_graphe.Count == 0)
        {
            <p class="config-graphe-vide" data-testid="graphe-vide">Aucun enfant, ajoutez-en.</p>
        }
        else
        {
            <ul class="config-graphe-racines">
                @foreach (var enfant in _graphe)
                {
                    <li class="config-graphe-racine" data-testid="graphe-enfant-racine" data-enfant-id="@enfant.EnfantId">
                        <span class="config-graphe-enfant" data-testid="graphe-enfant-nom">@enfant.Prenom</span>
                        @if (enfant.Parents.Count > 0)
                        {
                            <ul class="config-graphe-branches">
                                @foreach (var parent in enfant.Parents)
                                {
                                    <li class="config-graphe-branche" data-testid="graphe-parent-branche"
                                        data-enfant-id="@enfant.EnfantId" data-acteur-id="@parent.ActeurId">
                                        @LibelleBrancheParent(parent)
                                    </li>
                                }
                            </ul>
                        }
                    </li>
                }
            </ul>
        }
    </section>

    <div class="config-layout">
        <nav class="config-nav" aria-label="Sections de configuration">
            <button type="button" class="config-nav-item @(_onglet == "acteurs" ? "actif" : null)"
                    data-testid="onglet-acteurs" @onclick='() => ChoisirOnglet("acteurs")'>
                <span class="config-nav-ic" aria-hidden="true">👤</span>Acteurs
            </button>
            <button type="button" class="config-nav-item @(_onglet == "roles" ? "actif" : null)"
                    data-testid="onglet-roles" @onclick='() => ChoisirOnglet("roles")'>
                <span class="config-nav-ic" aria-hidden="true">🏷️</span>Rôles
            </button>
            <button type="button" class="config-nav-item @(_onglet == "cycles" ? "actif" : null)"
                    data-testid="onglet-cycles" @onclick='() => ChoisirOnglet("cycles")'>
                <span class="config-nav-ic" aria-hidden="true">🔁</span>Cycles
            </button>
            <button type="button" class="config-nav-item @(_onglet == "activites" ? "actif" : null)"
                    data-testid="onglet-activites" @onclick='() => ChoisirOnglet("activites")'>
                <span class="config-nav-ic" aria-hidden="true">📍</span>Activités
            </button>
            <button type="button" class="config-nav-item @(_onglet == "enfants" ? "actif" : null)"
                    data-testid="onglet-enfants" @onclick='() => ChoisirOnglet("enfants")'>
                <span class="config-nav-ic" aria-hidden="true">🧒</span>Enfants
            </button>
        </nav>

        <div class="config-panneaux">

            @* ══════════════ Panneau ACTEURS ══════════════ *@
            <section class="config-panneau @(_onglet == "acteurs" ? null : "cacher")"
                     data-testid="panneau-acteurs" aria-label="Acteurs">

                @* Refonte s32 (patron « tableau lecture seule + crayon → modal », brief refonte-config) :
                   la table des acteurs est PUREMENT EN LECTURE (pastille + nom, email + statut du compte,
                   rôle, état actif/admin en pastille/badge). Toute l'ÉCRITURE d'un acteur — nom, couleur,
                   rôle, compte, admin, suppression — est déportée dans la MODAL ouverte par le crayon de la
                   ligne (édition) ou par le bouton « Ajouter un acteur » (création). Réutilise les MÊMES
                   commandes CRUD (aucun handler neuf) et les mêmes testids d'écriture. Gating d'écriture sur
                   l'identité EFFECTIVE (règle 9) : crayon, bouton d'ajout et modal ne sont rendus que Parent. *@

                @if (_accuseSuppression is not null)
                {
                    <div class="alert alert-warning" role="status" data-testid="accuse-suppression">@_accuseSuppression</div>
                }
                @if (_accuseActivation is not null)
                {
                    <div class="alert alert-success" role="status" data-testid="accuse-activation">@_accuseActivation</div>
                }
                @if (_motifEchecSuppression is not null)
                {
                    <div class="alert alert-danger" data-testid="motif-echec-suppression">@_motifEchecSuppression</div>
                }

                <div class="acteurs-defilement">
                    <table class="acteurs-table" data-testid="liste-acteurs">
                        <thead>
                            <tr>
                                <th>Acteur</th>
                                <th>Rôle</th>
                                <th>Compte</th>
                                <th>État</th>
                                @if (Session.EstParent)
                                {
                                    <th class="acteurs-col-actions">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _acteurs)
                            {
                                <tr class="acteur-ligne" data-testid="acteur-foyer"
                                    data-acteur-id="@a.Id" data-couleur="@a.Couleur">
                                    <td>
                                        <span class="acteur-cell">
                                            <span class="acteur-pastille" style="background-color:@CouleursTheme.Pleine(a.Couleur);"
                                                  aria-hidden="true"></span>
                                            <span class="acteur-nom">@a.Nom</span>
                                        </span>
                                        @* Adresse de résidence (Sc.5) en LECTURE : ligne dédiée sous le nom, rendue seulement
                                           si renseignée (champ optionnel — absente = rien à afficher). *@
                                        @if (!string.IsNullOrEmpty(a.Adresse))
                                        {
                                            <div class="acteur-adresse" data-testid="acteur-adresse">@a.Adresse</div>
                                        }
                                    </td>
                                    <td>
                                        @* Rôle courant (lecture pour tous) : libellé résolu sur l'id stable du référentiel. *@
                                        <div class="acteur-role" data-testid="role-acteur-courant">@LibelleRoleActeur(a.RoleId)</div>
                                    </td>
                                    <td>
                                        @* Compte associé (LECTURE pour tous) : email + statut, s'il en porte un. La création /
                                           l'activation se font dans la modal (crayon), pas ici. *@
                                        @if (CompteDe(a.Id) is { } compte)
                                        {
                                            <span class="acteur-compte" data-testid="compte-acteur">
                                                @compte.Email — <span class="acteur-compte-statut">@compte.Statut</span>
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @* État actif/admin matérialisé en pastille/badge de LECTURE (pour tous). *@
                                        @if (CompteDe(a.Id) is { } c)
                                        {
                                            <span class="badge @(EstInactif(c) ? "bg-light text-dark" : "bg-success") acteur-etat-compte"
                                                  data-testid="acteur-etat-compte">@(EstInactif(c) ? "inactif" : "actif")</span>
                                        }
                                        @if (EstAdmin(a.Id))
                                        {
                                            <span class="badge bg-secondary acteur-admin" data-testid="acteur-admin-marqueur">admin</span>
                                        }
                                    </td>
                                    @if (Session.EstParent)
                                    {
                                        <td class="acteurs-col-actions">
                                            @* Crayon d'édition : ouvre la modal pré-remplie sur cet acteur (id stable porté). *@
                                            <button type="button" class="btn btn-outline-secondary btn-sm acteur-crayon"
                                                    data-testid="crayon-acteur" data-acteur-id="@a.Id"
                                                    @onclick="() => OuvrirEdition(a.Id)" aria-label="Modifier @a.Nom">✏️</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Session.EstParent)
                {
                    @* Bouton d'ajout au bas du tableau : ouvre la MÊME modal, champs vides (mode création). *@
                    <div class="acteurs-ajout">
                        <button type="button" class="btn btn-primary" data-testid="bouton-ajouter-acteur"
                                @onclick="OuvrirAjout">Ajouter un acteur</button>
                    </div>

                    @* ── MODAL acteur (édition OU ajout) ── rendue seulement quand ouverte et sous identité Parent.
                       Réutilise les commandes CRUD existantes et les testids d'écriture (champ-nom, palette-couleur,
                       selecteur-role-acteur, compte, admin, suppression). *@
                    @if (_modalAjout || _modalActeurId is not null)
                    {
                        var acteurEdite = _modalActeurId is null ? null : _acteurs.FirstOrDefault(x => x.Id == _modalActeurId);
                        <ModalConfig TestId="dialog-acteur" OnFermer="FermerModal">
                                <h2 class="h4 mb-3">@(_modalAjout ? "Ajouter un acteur" : "Modifier l'acteur")</h2>

                                @if (_modalAjout)
                                {
                                    @* Mode CRÉATION : champs vides, identifiant stable neuf posé côté handler. *@
                                    <EditForm Model="_ajout" OnValidSubmit="Ajouter" FormName="ajouter-acteur" id="form-ajout">
                                        <div class="mb-3">
                                            <label class="form-label">Nom</label>
                                            <InputText class="form-control" @bind-Value="_ajout.Nom" data-testid="champ-nom-ajout"
                                                       placeholder="Nom du nouvel acteur" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Couleur</label>
                                            @* Picker minimal (Sc.6) — même palette qu'en édition (set de couleurs réutilisé) : à la
                                               création, aucune couleur pré-sélectionnée (repli neutre par défaut côté handler). *@
                                            <div class="palette-couleurs" data-testid="palette-couleur-ajout" role="radiogroup"
                                                 aria-label="Couleur du nouvel acteur">
                                                @foreach (var c in CouleursTheme.Palette)
                                                {
                                                    var couleur = c;
                                                    <button type="button" data-testid="pastille-couleur-ajout-@couleur" data-couleur="@couleur"
                                                            class="palette-pastille @(_ajout.Couleur == couleur ? "selectionnee" : null)"
                                                            style="background-color:@CouleursTheme.Pleine(couleur);"
                                                            aria-pressed="@(_ajout.Couleur == couleur)" aria-label="@couleur"
                                                            @onclick="() => _ajout.Couleur = couleur"></button>
                                                }
                                            </div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                                            <button type="button" class="btn btn-link" data-testid="dialog-acteur-annuler"
                                                    @onclick="FermerModal">Annuler</button>
                                        </div>
                                    </EditForm>
                                    @if (_motifEchecAjout is not null)
                                    {
                                        <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec-ajout">@_motifEchecAjout</div>
                                    }
                                }
                                else if (acteurEdite is { } a)
                                {
                                    @* Mode ÉDITION : pré-rempli sur les champs courants ; l'id stable est porté par la modal
                                       (data-acteur-id), jamais éditable ni dérivé du libellé. *@
                                    <div data-testid="dialog-acteur-id" data-acteur-id="@a.Id"></div>

                                    <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="editer-acteur" id="form-edition">
                                        <div class="mb-3">
                                            <label class="form-label">Nom</label>
                                            <InputText class="form-control" @bind-Value="_form.Nom" data-testid="champ-nom"
                                                       placeholder="Nom de l'acteur" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Couleur</label>
                                            @* Picker minimal (Sc.6) : une PALETTE de pastilles cliquables réutilisant le set de
                                               couleurs (CouleursTheme.Palette), la couleur COURANTE pré-sélectionnée. HORS scope :
                                               aucune gestion de palette custom. La couleur choisie est persistée à l'« Enregistrer »
                                               via la commande existante editer-acteur (couleur). *@
                                            <div class="palette-couleurs" data-testid="palette-couleur" role="radiogroup"
                                                 aria-label="Couleur de l'acteur">
                                                @foreach (var c in CouleursTheme.Palette)
                                                {
                                                    var couleur = c;
                                                    <button type="button" data-testid="pastille-couleur-@couleur" data-couleur="@couleur"
                                                            class="palette-pastille @(_form.Couleur == couleur ? "selectionnee" : null)"
                                                            style="background-color:@CouleursTheme.Pleine(couleur);"
                                                            aria-pressed="@(_form.Couleur == couleur)" aria-label="@couleur"
                                                            @onclick="() => _form.Couleur = couleur"></button>
                                                }
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Adresse de résidence</label>
                                            @* Champ ADRESSE (Sc.5) : pré-rempli sur la valeur courante, éditable. Optionnel —
                                               une adresse vide est acceptée (Sc.1) et n'écrase pas les autres champs. *@
                                            <InputText class="form-control" @bind-Value="_form.Adresse" data-testid="champ-adresse"
                                                       placeholder="Adresse de résidence (optionnelle)" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Rôle</label>
                                            @* Sélecteur BORNÉ AU RÉFÉRENTIEL : exactement les rôles du foyer + « sans rôle ».
                                               La valeur bindée est l'id de rôle (jamais le libellé) ; vide = retrait. Appliqué
                                               immédiatement (commande existante affecter/retirer-role). *@
                                            <select class="form-select acteur-selecteur-role" data-testid="selecteur-role-acteur"
                                                    value="@(a.RoleId ?? "")"
                                                    @onchange="e => AffecterRole(a.Id, e.Value?.ToString())">
                                                <option value="">sans rôle</option>
                                                @foreach (var r in _roles)
                                                {
                                                    <option value="@r.Id">@r.Libelle</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                                            <button type="button" class="btn btn-link" data-testid="dialog-acteur-annuler"
                                                    @onclick="FermerModal">Annuler</button>
                                        </div>
                                    </EditForm>
                                    @if (_motifEchec is not null)
                                    {
                                        <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec">@_motifEchec</div>
                                    }

                                    <hr />

                                    @* Compte associé : compte existant (statut + activer), ou mini-formulaire de création
                                       (email obligatoire). Écriture via le canal HTTP ; sur refus, le motif reste dans la
                                       modal, sans compte créé. *@
                                    <div class="mb-3">
                                        <label class="form-label">Compte</label>
                                        @if (CompteDe(a.Id) is { } compte)
                                        {
                                            <div>
                                                <span class="acteur-compte" data-testid="compte-acteur-modal">
                                                    @compte.Email — <span class="acteur-compte-statut">@compte.Statut</span>
                                                </span>
                                            </div>
                                            @* Toggle ACTIF (Sc.4) — sens ON : actionnable seulement si le compte est INACTIF ;
                                               verrouillé (disabled) si déjà actif (désactivation absente du domaine ce sprint).
                                               Appliqué à l'« Enregistrer » via la commande existante activer-compte. *@
                                            <div class="form-check form-switch mt-2">
                                                <input type="checkbox" class="form-check-input acteur-toggle-actif" role="switch"
                                                       id="toggle-actif-@a.Id" data-testid="toggle-actif" @bind="_form.Actif"
                                                       disabled="@(!EstInactif(compte))" />
                                                <label class="form-check-label" for="toggle-actif-@a.Id">Compte actif</label>
                                            </div>
                                            @if (!EstInactif(compte))
                                            {
                                                <div class="text-muted small mt-1" data-testid="toggle-actif-motif">
                                                    Compte déjà actif (le retrait de l'activation arrivera dans un prochain incrément).</div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="acteur-compte-form">
                                                <input type="email" class="form-control acteur-champ-email"
                                                       data-testid="champ-email-compte" placeholder="email du compte"
                                                       @bind:get="EmailCompte(a.Id)" @bind:set="v => SaisirEmailCompte(a.Id, v)"
                                                       @bind:event="onchange" />
                                                <button type="button" class="btn btn-outline-primary btn-sm mt-2"
                                                        data-testid="bouton-creer-compte"
                                                        @onclick="() => CreerCompte(a.Id)">Créer le compte</button>
                                            </div>
                                            @if (MotifEchecCompte(a.Id) is { } motifCompte)
                                            {
                                                <div class="alert alert-danger py-1 px-2 mb-0 mt-2 acteur-compte-motif"
                                                     data-testid="motif-echec-compte">@motifCompte</div>
                                            }
                                            @* Toggle ACTIF désactivé : sans compte associé, rien à activer (motif dedans). *@
                                            <div class="form-check form-switch mt-2">
                                                <input type="checkbox" class="form-check-input acteur-toggle-actif" role="switch"
                                                       data-testid="toggle-actif" @bind="_form.Actif" disabled />
                                                <label class="form-check-label">Compte actif</label>
                                            </div>
                                            <div class="text-muted small mt-1" data-testid="toggle-actif-motif">
                                                Créez d'abord un compte pour pouvoir l'activer.</div>
                                        }
                                    </div>

                                    @* État ADMIN (Sc.4) — toggle sens ON : verrouillé (disabled) si l'acteur est DÉJÀ admin
                                       (la dé-désignation est absente du domaine ce sprint, reportée backlog). Appliqué à
                                       l'« Enregistrer » via la commande existante designer-admin. *@
                                    <div class="mb-3">
                                        <label class="form-label">Admin</label>
                                        <div class="form-check form-switch">
                                            <input type="checkbox" class="form-check-input acteur-toggle-admin" role="switch"
                                                   id="toggle-admin-@a.Id" data-testid="toggle-admin" @bind="_form.Admin"
                                                   disabled="@EstAdmin(a.Id)" />
                                            <label class="form-check-label" for="toggle-admin-@a.Id">Administrateur du foyer</label>
                                        </div>
                                        @if (EstAdmin(a.Id))
                                        {
                                            <div class="text-muted small mt-1" data-testid="toggle-admin-motif">
                                                Déjà administrateur (le retrait arrivera dans un prochain incrément).</div>
                                        }
                                    </div>

                                    <hr />

                                    @* Suppression de l'acteur (commande existante) : sur succès, ferme la modal et retire
                                       l'acteur de la table (cases orphelines → fond/neutre, sans nom fantôme). *@
                                    <button type="button" class="btn btn-outline-danger btn-sm acteur-supprimer"
                                            data-testid="bouton-supprimer" data-acteur-id="@a.Id"
                                            @onclick="() => Supprimer(a.Id)" aria-label="Supprimer @a.Nom">Supprimer cet acteur</button>
                                }
                        </ModalConfig>
                    }
                }
            </section>

            @* ══════════════ Panneau RÔLES ══════════════ *@
            <section class="config-panneau @(_onglet == "roles" ? null : "cacher")"
                     data-testid="panneau-roles" aria-label="Rôles">
                @* Refonte s33 (Sc.8) : patron « tableau lecture seule + crayon → modal » (comme Acteurs s32).
                   La table des rôles est PUREMENT EN LECTURE ; toute l'écriture (créer / renommer / supprimer)
                   est déportée dans la MODAL ouverte par le crayon (édition) ou « Ajouter un rôle » (création).
                   Réutilise les MÊMES commandes existantes (POST /api/canal/{creer,renommer,supprimer}-role,
                   aucun handler neuf). Gating d'écriture sur l'identité EFFECTIVE (règle 9) : crayon, bouton
                   d'ajout et modal ne sont rendus que Parent ; la table reste visible en lecture pour tous. *@
                <h2 class="config-panneau-titre">Rôles du foyer</h2>
                <p class="text-muted">Le référentiel de rôles (Nounou, Grand-parent…) ; un rôle reçoit un
                    identifiant stable neuf (jamais dérivé du libellé) et peut être affecté à un acteur. Créer,
                    renommer ou supprimer un rôle met la table à jour sans recharger la page.</p>

                <div class="acteurs-defilement">
                    <table class="acteurs-table" data-testid="liste-roles">
                        <thead>
                            <tr>
                                <th>Rôle</th>
                                @if (Session.EstParent)
                                {
                                    <th class="acteurs-col-actions">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _roles)
                            {
                                <tr data-testid="role-foyer" data-role-id="@r.Id">
                                    <td><span class="role-libelle">@r.Libelle</span></td>
                                    @if (Session.EstParent)
                                    {
                                        <td class="acteurs-col-actions">
                                            <button type="button" class="btn btn-outline-secondary btn-sm acteur-crayon"
                                                    data-testid="crayon-role" data-role-id="@r.Id"
                                                    @onclick="() => OuvrirEditionRole(r.Id)" aria-label="Modifier @r.Libelle">✏️</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Session.EstParent)
                {
                    <div class="acteurs-ajout">
                        <button type="button" class="btn btn-primary" data-testid="bouton-ajouter-role"
                                @onclick="OuvrirAjoutRole">Ajouter un rôle</button>
                    </div>

                    @* MODAL rôle (édition OU ajout) — rendue seulement quand ouverte et sous Parent. *@
                    @if (_modalRoleAjout || _modalRoleId is not null)
                    {
                        <ModalConfig TestId="dialog-role" OnFermer="FermerModalRole">
                                <h2 class="h4 mb-3">@(_modalRoleAjout ? "Ajouter un rôle" : "Modifier le rôle")</h2>
                                <EditForm Model="_role" OnValidSubmit="SoumettreRole" FormName="role" id="form-role">
                                    <div class="mb-3">
                                        <label class="form-label">Libellé</label>
                                        <InputText class="form-control" @bind-Value="_role.Libelle" data-testid="champ-libelle-role"
                                                   placeholder="Libellé du rôle (ex. Nounou)" />
                                    </div>
                                    @* Sc.6 (s36) — case « rôle parent » (édition seule) : reflète le flag COURANT du rôle
                                       (source de vérité de l'éligibilité au lien enfant↔parent, jamais le libellé). Un rôle
                                       créé démarre non-parent (Sc.3), la case n'apparaît qu'en édition. *@
                                    @if (!_modalRoleAjout)
                                    {
                                        <div class="mb-3 form-check form-switch">
                                            <input type="checkbox" class="form-check-input" role="switch" id="role-parent-flag"
                                                   data-testid="checkbox-role-parent" checked="@_role.EstParent"
                                                   @onchange="e => _role.EstParent = (bool)e.Value!" />
                                            <label class="form-check-label" for="role-parent-flag">
                                                Rôle parent (les acteurs qui le portent sont liables comme parents d'un enfant)</label>
                                        </div>
                                    }
                                    <div class="d-flex gap-2">
                                        <button type="submit" class="btn btn-primary">Enregistrer</button>
                                        <button type="button" class="btn btn-link" data-testid="dialog-role-annuler"
                                                @onclick="FermerModalRole">Annuler</button>
                                    </div>
                                </EditForm>
                                @if (_motifEchecRole is not null)
                                {
                                    <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec-role">@_motifEchecRole</div>
                                }
                                @if (!_modalRoleAjout && _modalRoleId is { } rid)
                                {
                                    <hr />
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            data-testid="bouton-supprimer-role" data-role-id="@rid"
                                            @onclick="() => SupprimerRole(rid)">Supprimer ce rôle</button>
                                }
                        </ModalConfig>
                    }
                }
            </section>

            @* ══════════════ Panneau CYCLES ══════════════ *@
            <section class="config-panneau @(_onglet == "cycles" ? null : "cacher")"
                     data-testid="panneau-periode-garde" aria-label="Cycle de fond">
                @* Refonte s33 (Sc.10) : patron « tableau lecture seule + crayon → modal ». Le tableau rend
                   VISIBLES toutes les affectations déclarées du cycle (query Sc.3), y compris celles auparavant
                   invisibles (retour PO gate s32) ; il reste visible en lecture pour toutes les identités.
                   L'éditeur EXISTANT (N + un select par semaine → definir-cycle, atomique) est DÉPLACÉ dans la
                   MODAL ouverte par le crayon « Éditer le cycle » (gating Parent) — l'inline #form-cycle n'est
                   plus rendu hors modal. Aucun découpage per-semaine (definir-cycle reste atomique). *@
                <h2 class="config-panneau-titre">Cycle de fond (responsabilité par défaut)</h2>
                <p class="text-muted">Les semaines du cycle et leur responsable de fond. Les jours sans période
                    explicite suivent ce cycle ; la grille se met à jour sans recharger la page.</p>

                <div class="acteurs-defilement">
                    <table class="acteurs-table" data-testid="liste-cycles">
                        <thead>
                            <tr>
                                <th>Semaine</th>
                                <th>Responsable de fond</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _cyclesDeclares.OrderBy(x => x.IndexSemaine))
                            {
                                <tr data-testid="cycle-foyer" data-cycle-index="@c.IndexSemaine">
                                    <td><span class="role-libelle">@LibelleSemaineCycle(c.IndexSemaine)</span></td>
                                    <td><span class="cycle-responsable">@NomResponsableCycle(c.ResponsableId)</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Session.EstParent)
                {
                    <div class="acteurs-ajout">
                        <button type="button" class="btn btn-primary acteur-crayon" data-testid="crayon-cycle"
                                @onclick="OuvrirEditionCycle" aria-label="Éditer le cycle">✏️ Éditer le cycle</button>
                    </div>

                    @if (_confirmationCycle is not null)
                    {
                        <div class="alert alert-success mt-3" data-testid="confirmation-cycle">@_confirmationCycle</div>
                    }

                    @* MODAL cycle — héberge l'éditeur EXISTANT (N + selects par semaine) déplacé de l'inline. *@
                    @if (_modalCycleOuverte)
                    {
                        <ModalConfig TestId="dialog-cycle" OnFermer="FermerModalCycle">
                                <h2 class="h4 mb-3">Éditer le cycle de fond</h2>
                                <EditForm Model="_cycle" OnValidSubmit="DefinirCycle" FormName="definir-cycle" id="form-cycle">
                                    <div class="mb-3">
                                        <label class="form-label">Nombre de semaines du cycle</label>
                                        <InputNumber class="form-control" @bind-Value="_cycle.NombreSemaines"
                                                     @bind-Value:after="StateHasChanged" data-testid="champ-nombre-semaines" min="1" />
                                    </div>
                                    <div class="cycle-semaines">
                                        @for (var i = 0; i < _cycle.NombreSemaines && i < 12; i++)
                                        {
                                            var index = i;
                                            <div class="cycle-carte">
                                                <label class="cycle-carte-label">@LibelleSemaineCycle(index)</label>
                                                <select class="form-select" data-testid="champ-cycle-index-@index"
                                                        value="@(_cycle.Affectations.TryGetValue(index, out var r) ? r : "")"
                                                        @onchange="e => AffecterIndex(index, e.Value?.ToString())">
                                                    <option value="">— aucun (teinte neutre) —</option>
                                                    @foreach (var a in _acteurs)
                                                    {
                                                        <option value="@a.Id">@a.Nom</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex gap-2 mt-3">
                                        <button type="submit" class="btn btn-primary">Définir le cycle</button>
                                        <button type="button" class="btn btn-link" data-testid="dialog-cycle-annuler"
                                                @onclick="FermerModalCycle">Annuler</button>
                                    </div>
                                </EditForm>

                                @if (_motifEchecCycle is not null)
                                {
                                    <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec-cycle">@_motifEchecCycle</div>
                                }
                        </ModalConfig>
                    }
                }
            </section>

            @* ══════════════ Panneau ACTIVITÉS ══════════════ *@
            <section class="config-panneau @(_onglet == "activites" ? null : "cacher")"
                     data-testid="panneau-activites" aria-label="Activités">
                @* Refonte s35 (Sc.4) : patron « tableau lecture seule + crayon → modal » (comme Acteurs s32 /
                   Enfants s34). Le référentiel de « lieux » (s27) devient « Activités » liées à l'enfant. La
                   table des activités est PUREMENT EN LECTURE (libellé + adresse + colonne « Enfants liés »
                   résolue en prénoms) ; toute l'écriture (ajouter / éditer libellé + adresse, supprimer, et —
                   Sc.5 — lier/délier des enfants) est déportée dans la MODAL ouverte par le crayon (édition) ou
                   « Ajouter une activité » (création). Les activités disponibles à la saisie (sélecteurs des
                   dialogs Poser un slot / Définir un transfert, axe LOCALISATION du slot préservé) proviennent
                   EXCLUSIVEMENT de ce référentiel vivant. Écritures via le canal HTTP (POST
                   /api/canal/{ajouter,editer,supprimer}-activite). Gating d'identité EFFECTIVE (règle 9) : crayon,
                   bouton d'ajout et modal ne sont rendus que Parent ; la table reste visible en lecture pour tous. *@
                <h2 class="config-panneau-titre">Activités du foyer</h2>
                <p class="text-muted">Le référentiel d'activités (école, nounou, piscine…) et, pour chacune, son
                    adresse et les enfants liés. Une activité ajoutée devient aussitôt disponible à la saisie d'un
                    slot ou d'un transfert ; une activité supprimée n'est plus proposée. La table suit sans
                    recharger la page.</p>

                <div class="acteurs-defilement">
                    <table class="acteurs-table" data-testid="liste-activites">
                        <thead>
                            <tr>
                                <th>Activité</th>
                                <th>Adresse</th>
                                <th>Enfants liés</th>
                                @if (Session.EstParent)
                                {
                                    <th class="acteurs-col-actions">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _activites)
                            {
                                <tr data-testid="activite-foyer" data-activite-id="@a.Id">
                                    <td><span class="role-libelle">@a.Libelle</span></td>
                                    <td>
                                        @* Adresse (Sc.2) en LECTURE : rendue seulement si renseignée (champ optionnel). *@
                                        @if (!string.IsNullOrEmpty(a.Adresse))
                                        {
                                            <span class="acteur-adresse" data-testid="activite-adresse">@a.Adresse</span>
                                        }
                                    </td>
                                    <td>
                                        @* Colonne « Enfants liés » en LECTURE : les identifiants stables des enfants
                                           résolus en prénoms (jamais un libellé en dur) ; « — » si aucun. *@
                                        <span class="enfant-parents-lies" data-testid="activite-enfants-lies">@LibelleEnfantsLies(a)</span>
                                    </td>
                                    @if (Session.EstParent)
                                    {
                                        <td class="acteurs-col-actions">
                                            <button type="button" class="btn btn-outline-secondary btn-sm acteur-crayon"
                                                    data-testid="crayon-activite" data-activite-id="@a.Id"
                                                    @onclick="() => OuvrirEditionActivite(a.Id)" aria-label="Modifier @a.Libelle">✏️</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Session.EstParent)
                {
                    <div class="acteurs-ajout">
                        <button type="button" class="btn btn-primary" data-testid="bouton-ajouter-activite"
                                @onclick="OuvrirAjoutActivite">Ajouter une activité</button>
                    </div>

                    @* MODAL activité (édition OU ajout) — rendue seulement quand ouverte et sous Parent. Réutilise
                       les commandes existantes ajouter-activite / editer-activite / supprimer-activite ; le
                       sélecteur d'enfants à lier/délier arrive en Sc.5. *@
                    @if (_modalActiviteAjout || _modalActiviteId is not null)
                    {
                        var activiteEditee = _modalActiviteId is null ? null : _activites.FirstOrDefault(x => x.Id == _modalActiviteId);
                        <ModalConfig TestId="dialog-activite" OnFermer="FermerModalActivite">
                            <h2 class="h4 mb-3">@(_modalActiviteAjout ? "Ajouter une activité" : "Modifier l'activité")</h2>

                            @if (!_modalActiviteAjout && activiteEditee is { } act)
                            {
                                <div data-testid="dialog-activite-id" data-activite-id="@act.Id"></div>
                            }

                            <EditForm Model="_activite" OnValidSubmit="SoumettreActivite" FormName="activite" id="form-activite">
                                <div class="mb-3">
                                    <label class="form-label">Libellé</label>
                                    <InputText class="form-control" @bind-Value="_activite.Libelle" data-testid="champ-libelle-activite"
                                               placeholder="Libellé de l'activité (ex. piscine)" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Adresse</label>
                                    @* Champ ADRESSE (Sc.2) : pré-rempli sur la valeur courante, éditable. Optionnel —
                                       une adresse vide est acceptée et n'écrase pas le libellé (surfaces indépendantes). *@
                                    <InputText class="form-control" @bind-Value="_activite.Adresse" data-testid="champ-adresse-activite"
                                               placeholder="Adresse de l'activité (optionnelle)" />
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                                    <button type="button" class="btn btn-link" data-testid="dialog-activite-annuler"
                                            @onclick="FermerModalActivite">Annuler</button>
                                </div>
                            </EditForm>

                            @if (_motifEchecActivite is not null)
                            {
                                <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec-activite">@_motifEchecActivite</div>
                            }

                            @if (!_modalActiviteAjout && activiteEditee is { } act2)
                            {
                                @* Enfants liés COURANTS en lecture (Sc.4) : la modal montre les enfants actuels
                                   de l'activité, résolus en prénoms. *@
                                <hr />
                                <div class="mb-2">
                                    <label class="form-label">Enfants liés</label>
                                    <div class="enfant-parents-lies-modal" data-testid="activite-enfants-lies-modal">@LibelleEnfantsLies(act2)</div>
                                </div>

                                @* SÉLECTEUR des enfants à lier / délier (Sc.5) : tout le référentiel d'enfants (s30),
                                   les enfants DÉJÀ liés pré-cochés. Lien N-M : AUCUNE borne de cardinalité (0..N).
                                   À l'« Enregistrer » (SoumettreActivite), les diffs vis-à-vis des enfants courants
                                   émettent lier-enfant-activite / delier-enfant-activite via le canal HTTP. HORS
                                   scope : liste de slots par activité, lien adresse acteur↔lieu. *@
                                <div class="mb-2" data-testid="selecteur-enfants-activite">
                                    <label class="form-label">Lier des enfants</label>
                                    @if (!_enfants.Any())
                                    {
                                        <div class="text-muted small" data-testid="aucun-enfant-candidat">
                                            Aucun enfant dans le référentiel.</div>
                                    }
                                    @foreach (var enf in _enfants)
                                    {
                                        var enfant = enf;
                                        var lie = _selectionEnfants.Contains(enfant.Id);
                                        <div class="form-check form-switch">
                                            <input type="checkbox" class="form-check-input enfant-checkbox-parent" role="switch"
                                                   id="enfant-activite-@enfant.Id" data-testid="checkbox-enfant-activite" data-enfant-id="@enfant.Id"
                                                   checked="@lie" @onchange="e => BasculerEnfant(enfant.Id, (bool)e.Value!)" />
                                            <label class="form-check-label" for="enfant-activite-@enfant.Id">@enfant.Prenom</label>
                                        </div>
                                    }
                                </div>

                                <hr />
                                <button type="button" class="btn btn-outline-danger btn-sm"
                                        data-testid="bouton-supprimer-activite" data-activite-id="@act2.Id"
                                        @onclick="() => SupprimerActivite(act2.Id)" aria-label="Supprimer @act2.Libelle">Supprimer cette activité</button>
                            }
                        </ModalConfig>
                    }
                }
            </section>

            @* ══════════════ Panneau ENFANTS ══════════════ *@
            <section class="config-panneau @(_onglet == "enfants" ? null : "cacher")"
                     data-testid="panneau-enfants" aria-label="Enfants">
                @* Refonte s34 (Sc.4) : patron « tableau lecture seule + crayon → modal » (comme Acteurs s32 /
                   Rôles-Cycle s33). La table des enfants est PUREMENT EN LECTURE (prénom + colonne « Parents
                   liés » résolue en noms d'acteurs) ; toute l'écriture (ajouter / éditer le prénom, et — Sc.5 —
                   lier/délier des parents) est déportée dans la MODAL ouverte par le crayon (édition) ou
                   « Ajouter un enfant » (création). Réutilise les MÊMES commandes existantes (POST
                   /api/canal/{ajouter,editer}-enfant) ; l'inline préexistant (form-ajouter-enfant,
                   champ-editer-enfant) n'est PLUS rendu (lot atomique de surface). Gating d'identité EFFECTIVE
                   (règle 9) : crayon, bouton d'ajout et modal ne sont rendus que Parent ; la table reste
                   visible en lecture pour tous. *@
                <h2 class="config-panneau-titre">Enfants du foyer</h2>
                <p class="text-muted">Le référentiel d'enfants (Léa, Tom…) et, pour chacun, ses parents liés (0..2).
                    Un enfant ajouté reçoit un identifiant stable neuf (jamais dérivé du prénom) ; éditer un prénom
                    conserve l'identifiant. La table suit sans recharger la page.</p>

                <div class="acteurs-defilement">
                    <table class="acteurs-table" data-testid="liste-enfants">
                        <thead>
                            <tr>
                                <th>Enfant</th>
                                <th>Parents liés</th>
                                @if (Session.EstParent)
                                {
                                    <th class="acteurs-col-actions">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in _enfants)
                            {
                                <tr data-testid="enfant-foyer" data-enfant-id="@e.Id">
                                    <td><span class="role-libelle">@e.Prenom</span></td>
                                    <td>
                                        @* Colonne « Parents liés » en LECTURE : les identifiants stables des parents
                                           résolus en noms d'acteurs (jamais un libellé en dur) ; « — » si aucun. *@
                                        <span class="enfant-parents-lies" data-testid="enfant-parents-lies">@LibelleParentsLies(e)</span>
                                    </td>
                                    @if (Session.EstParent)
                                    {
                                        <td class="acteurs-col-actions">
                                            <button type="button" class="btn btn-outline-secondary btn-sm acteur-crayon"
                                                    data-testid="crayon-enfant" data-enfant-id="@e.Id"
                                                    @onclick="() => OuvrirEditionEnfant(e.Id)" aria-label="Modifier @e.Prenom">✏️</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Session.EstParent)
                {
                    <div class="acteurs-ajout">
                        <button type="button" class="btn btn-primary" data-testid="bouton-ajouter-enfant"
                                @onclick="OuvrirAjoutEnfant">Ajouter un enfant</button>
                    </div>

                    @* MODAL enfant (édition OU ajout) — rendue seulement quand ouverte et sous Parent. Réutilise
                       les commandes existantes ajouter-enfant / editer-enfant ; le sélecteur de parents à
                       lier/délier arrive en Sc.5. *@
                    @if (_modalEnfantAjout || _modalEnfantId is not null)
                    {
                        var enfantEdite = _modalEnfantId is null ? null : _enfants.FirstOrDefault(x => x.Id == _modalEnfantId);
                        <ModalConfig TestId="dialog-enfant" OnFermer="FermerModalEnfant">
                            <h2 class="h4 mb-3">@(_modalEnfantAjout ? "Ajouter un enfant" : "Modifier l'enfant")</h2>

                            @if (!_modalEnfantAjout && enfantEdite is { } enf)
                            {
                                <div data-testid="dialog-enfant-id" data-enfant-id="@enf.Id"></div>
                            }

                            <EditForm Model="_enfant" OnValidSubmit="SoumettreEnfant" FormName="enfant" id="form-enfant">
                                <div class="mb-3">
                                    <label class="form-label">Prénom</label>
                                    <InputText class="form-control" @bind-Value="_enfant.Prenom" data-testid="champ-prenom-enfant"
                                               placeholder="Prénom de l'enfant (ex. Tom)" />
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                                    <button type="button" class="btn btn-link" data-testid="dialog-enfant-annuler"
                                            @onclick="FermerModalEnfant">Annuler</button>
                                </div>
                            </EditForm>

                            @if (_motifEchecEnfant is not null)
                            {
                                <div class="alert alert-danger mt-3 mb-0" data-testid="motif-echec-enfant">@_motifEchecEnfant</div>
                            }

                            @if (!_modalEnfantAjout && enfantEdite is { } e2)
                            {
                                @* Parents liés COURANTS en lecture (Sc.4) : la modal montre les parents actuels
                                   de l'enfant, résolus en noms. *@
                                <hr />
                                <div class="mb-2">
                                    <label class="form-label">Parents liés</label>
                                    <div class="enfant-parents-lies-modal" data-testid="enfant-parents-lies-modal">@LibelleParentsLies(e2)</div>
                                </div>

                                @* SÉLECTEUR des parents à lier / délier (Sc.5) : exactement les acteurs portant le
                                   rôle « Parent » (référentiel acteurs + rôles), les parents DÉJÀ liés pré-cochés.
                                   Borne « 2 parents max » (Sc.2) reflétée à l'écran : une case non cochée est
                                   désactivée quand 2 sont déjà sélectionnés. À l'« Enregistrer » (SoumettreEnfant),
                                   les diffs vis-à-vis des parents courants émettent lier-enfant-parent /
                                   delier-enfant-parent via le canal HTTP. HORS scope : familles recomposées /
                                   exactement-2 / vue graphe. *@
                                <div class="mb-2" data-testid="selecteur-parents-enfant">
                                    <label class="form-label">Lier des parents (2 max)</label>
                                    @if (!ActeursParents().Any())
                                    {
                                        <div class="text-muted small" data-testid="aucun-parent-candidat">
                                            Aucun acteur ne porte un rôle marqué « parent ».</div>
                                    }
                                    @foreach (var p in ActeursParents())
                                    {
                                        var acteur = p;
                                        var lie = _selectionParents.ContainsKey(acteur.Id);
                                        var role = RoleDeParent(acteur.Id);
                                        <div class="form-check form-switch d-flex align-items-center gap-2">
                                            <input type="checkbox" class="form-check-input enfant-checkbox-parent" role="switch"
                                                   id="parent-@acteur.Id" data-testid="checkbox-parent" data-acteur-id="@acteur.Id"
                                                   checked="@lie" disabled="@(!lie && _selectionParents.Count >= 2)"
                                                   @onchange="e => BasculerParent(acteur.Id, (bool)e.Value!)" />
                                            <label class="form-check-label" for="parent-@acteur.Id">@acteur.Nom</label>
                                            @* Sélecteur rôle-du-lien (s37) : visible pour un parent SÉLECTIONNÉ, pré-réglé
                                               sur son rôle courant. À l'« Enregistrer », le rôle voyage avec « lier ». *@
                                            @if (lie)
                                            {
                                                <select class="form-select form-select-sm enfant-role-parent" data-testid="role-parent-select"
                                                        data-acteur-id="@acteur.Id"
                                                        @onchange="e => ChoisirRoleParent(acteur.Id, Enum.Parse<RoleDuLien>((string)e.Value!))">
                                                    <option value="ParentLibre" selected="@(role == RoleDuLien.ParentLibre)">parent</option>
                                                    <option value="Pere" selected="@(role == RoleDuLien.Pere)">père</option>
                                                    <option value="Mere" selected="@(role == RoleDuLien.Mere)">mère</option>
                                                </select>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </ModalConfig>
                    }
                }
            </section>

        </div>
    </div>
</div>

<style>
    /* Configuration « Studio » : mise en page façon settings (barre latérale gauche + panneau), tokenisée
       (clair ET sombre). Les pastilles de couleur d'acteur restent INLINE (donnée). */

    .config-entete { margin-bottom: 1.5rem; }
