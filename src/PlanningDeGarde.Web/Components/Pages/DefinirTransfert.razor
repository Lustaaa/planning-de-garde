@page "/planning/definir-transfert"
@inject HttpClient Canal
@inject SessionPlanning Session
@inject NavigationManager Nav
@using static PlanningDeGarde.Web.CanalEcriture

<PageTitle>Définir un transfert</PageTitle>

<h1 class="h3 mb-3">Définir le transfert de bascule</h1>

@if (!Session.EstParent)
{
    <div class="alert alert-warning">Action réservée aux Parents. Vous êtes en consultation seule.</div>
}
else
{
    <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="definir-transfert">
        <div class="row">
            <div class="col mb-3">
                <label class="form-label">Dépose par</label>
                <InputSelect class="form-select" @bind-Value="_form.DeposeParId">
                    <option value="">— choisir —</option>
                    @foreach (var r in Foyer.Responsables)
                    {
                        <option value="@r">@r</option>
                    }
                </InputSelect>
            </div>
            <div class="col mb-3">
                <label class="form-label">Récupère par</label>
                <InputSelect class="form-select" @bind-Value="_form.RecupereParId">
                    <option value="">— choisir —</option>
                    @foreach (var r in Foyer.Responsables)
                    {
                        <option value="@r">@r</option>
                    }
                </InputSelect>
            </div>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label class="form-label">Lieu</label>
                <InputSelect class="form-select" @bind-Value="_form.LieuId">
                    <option value="">— choisir —</option>
                    @foreach (var lieu in Foyer.Lieux)
                    {
                        <option value="@lieu">@lieu</option>
                    }
                </InputSelect>
            </div>
            <div class="col mb-3">
                <label class="form-label">Date</label>
                <InputDate class="form-control" @bind-Value="_form.Date" />
            </div>
            <div class="col mb-3">
                <label class="form-label">Heure</label>
                <input type="time" class="form-control" @bind="_heure" @bind:format="HH:mm" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Définir le transfert</button>
        <a href="planning" class="btn btn-link">Retour au planning</a>
    </EditForm>
}

@if (_motifEchec is not null)
{
    <div class="alert alert-danger mt-3" data-testid="motif-echec">@_motifEchec</div>
}

@code {
    private sealed class Formulaire
    {
        public string DeposeParId { get; set; } = "";
        public string RecupereParId { get; set; } = "";
        public string LieuId { get; set; } = "";
        public DateTime Date { get; set; } = new(2025, 7, 21);
    }

    private readonly Formulaire _form = new();
    private TimeOnly? _heure = new(8, 30);
    private string? _motifEchec;

    private async Task Soumettre()
    {
        _motifEchec = null;
        var heure = _heure?.ToTimeSpan() ?? TimeSpan.Zero;

        // Émission de la commande d'écriture via le canal HTTP de l'API distante (adaptateur de
        // gauche), JAMAIS par un handler en DI direct (impossible côté navigateur).
        HttpResponseMessage reponse;
        try
        {
            reponse = await Canal.PostAsJsonAsync(
                "api/canal/definir-transfert",
                new DefinirTransfertRequete(_form.DeposeParId, _form.RecupereParId, _form.LieuId, heure, _form.Date));
        }
        catch (HttpRequestException)
        {
            _motifEchec = PoserSlot.MessageServiceInjoignable;
            return;
        }

        if (reponse.IsSuccessStatusCode)
            Nav.NavigateTo("planning");
        else
            _motifEchec = await reponse.Content.ReadAsStringAsync();
    }
}
