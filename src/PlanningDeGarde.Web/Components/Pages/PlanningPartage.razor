@page "/planning"
@implements IAsyncDisposable
@inject HttpClient Canal
@inject SessionPlanning Session
@inject NavigationManager Nav
@inject IDateTimeProvider Horloge
@inject OptionsConnexionHub OptionsHub

<PageTitle>Planning partagé</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="m-0">Planning partagé du foyer</h1>
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted">Rôle :</span>
        <select class="form-select form-select-sm w-auto" @bind="RoleSelectionne">
            <option value="@RoleAuteur.Parent">Parent</option>
            <option value="@RoleAuteur.Invite">Invité (consultation seule)</option>
        </select>
    </div>
</div>

@if (!Session.EstParent)
{
    <div class="alert alert-info py-2">Vous consultez en lecture seule. Les actions d'édition sont désactivées.</div>
}

@* Avertissement de chevauchement « à part » (Sc.7) : la pose chevauchante est ACCEPTÉE (règle 16),
   l'avertissement s'affiche dans un bandeau hors de la dialog, NON bloquant (refermable). *@
@if (_avertissementChevauchement)
{
    <div class="alert alert-warning alert-dismissible py-2" data-testid="avertissement-chevauchement" role="alert">
        Chevauchement signalé : le créneau posé en recouvre un autre le même jour (accepté, à vérifier).
        <button type="button" class="btn-close" aria-label="Fermer" @onclick="FermerAvertissement"></button>
    </div>
}

@* Accusé « Transfert défini » à part (Sc.1) : feedback transitoire NON bloquant, levé sur le simple
   succès HTTP du canal (aucun rendu en case ni read model neuf — règle 27, panneau cloche hors scope).
   Refermable, mécanisme du bandeau d'avertissement réutilisé. *@
@if (_accuseTransfertDefini)
{
    <div class="alert alert-success alert-dismissible py-2" data-testid="accuse-transfert-defini" role="status">
        Transfert défini.
        <button type="button" class="btn-close" aria-label="Fermer" @onclick="FermerAccuseTransfert"></button>
    </div>
}

@* Palier 7 : la pose de slot et l'affectation de période se font désormais EN CONTEXTE (clic sur une
   case → menu d'actions → dialog). Les liens-barre dédiés sont retirés ; seul « Définir un transfert »
   subsiste (3e dialog transfert déférée au backlog). *@
<div class="mb-3 d-flex gap-2">
    <a class="btn btn-primary @Desactive" href="planning/definir-transfert">Définir un transfert</a>
</div>

<section class="grille-agenda" data-testid="grille-agenda">
    <div class="grille-entete">
        @foreach (var jour in JoursDeLaSemaine)
        {
            <div class="grille-entete-jour">@jour</div>
        }
    </div>

    @foreach (var semaine in _grille.Semaines)
    {
        <div class="grille-semaine">
            @foreach (var jourCase in semaine.Jours)
            {
                <div class="grille-jour @(Session.EstParent ? "grille-jour-cliquable" : null)" data-testid="jour-case"
                     data-couleur="@jourCase.CouleurResponsable"
                     style="background-color:@Teinte(jourCase.CouleurResponsable);"
                     @onclick="@(() => OuvrirMenu(jourCase.Date))">
                    <div class="grille-jour-date">@jourCase.Date.ToString("dd/MM")</div>
                    @if (!string.IsNullOrEmpty(jourCase.NomResponsable))
                    {
                        @* Lisibilité du nom long (Sc.6) : troncature visuelle (CSS) dans la case, nom
                           complet accessible au survol (title). La donnée reste intègre (texte complet). *@
                        <div class="grille-jour-responsable nom-tronque" data-testid="nom-responsable"
                             title="@jourCase.NomResponsable">@jourCase.NomResponsable</div>
                    }
                    <div class="grille-jour-slots">
                        @foreach (var slot in jourCase.Slots)
                        {
                            <div class="grille-slot" data-testid="slot-case"
                                 style="background-color:@Couleur(slot.CouleurActeur);">
                                <span class="grille-slot-libelle">@slot.Libelle</span>
                                <span class="grille-slot-horaire">@slot.Debut.ToString("HH:mm")–@slot.Fin.ToString("HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</section>

<Legende Entrees="_grille.Légende" />

@* Menu d'actions de la case (décision CP, palier 7) : un seul déclencheur d'écriture par case
   (mutualise le gating Invité, Sc.6), deux entrées ouvrant chacune sa dialog pré-remplie sur la
   date de la case. La grille reste en lecture seule : le menu n'écrit jamais. *@
@if (_dateMenu is { } dateMenu)
{
    <div class="menu-backdrop" data-testid="menu-actions-case" @onclick="FermerMenu">
        <div class="menu-panneau" @onclick:stopPropagation="true">
            <h2 class="h6 mb-3">@dateMenu.ToString("dd/MM/yyyy")</h2>
            <button type="button" class="btn btn-outline-primary w-100 mb-2" data-testid="action-poser-slot"
                    @onclick="@(() => OuvrirPoserSlot(dateMenu))">Poser un slot</button>
            <button type="button" class="btn btn-outline-primary w-100 mb-2" data-testid="action-affecter-periode"
                    @onclick="@(() => OuvrirAffecterPeriode(dateMenu))">Affecter une période</button>
            <button type="button" class="btn btn-outline-primary w-100" data-testid="action-definir-transfert"
                    @onclick="@(() => OuvrirDefinirTransfert(dateMenu))">Définir un transfert</button>
        </div>
    </div>
}

@if (_dateDialogPoserSlot is { } datePoserSlot)
{
    <PoserSlotDialog DateContexte="datePoserSlot"
                     OnValide="FermerPoserSlotEtRecharger"
                     OnAnnule="FermerDialog" />
}

@if (_dateDialogAffecterPeriode is { } dateAffecter)
{
    <AffecterPeriodeDialog DateContexte="dateAffecter"
                           OnValide="FermerDialogEtRecharger"
                           OnAnnule="FermerDialog" />
}

@if (_dateDialogDefinirTransfert is { } dateTransfert)
{
    <DefinirTransfertDialog DateContexte="dateTransfert"
                            OnValide="FermerTransfertEtAccuser"
                            OnAnnule="FermerDialog" />
}

<style>
    .grille-agenda { display: flex; flex-direction: column; gap: 4px; }
    .grille-entete, .grille-semaine { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
    .grille-entete-jour { font-weight: 600; text-align: center; color: #555; padding: 2px 0; }
    .grille-jour { min-height: 90px; border: 1px solid #dee2e6; border-radius: 4px; padding: 4px; display: flex; flex-direction: column; gap: 4px; }
    .grille-jour-cliquable { cursor: pointer; }
    .menu-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.3); display: flex;
                     align-items: center; justify-content: center; z-index: 1040; }
    .menu-panneau { background: #fff; border-radius: 6px; padding: 16px; width: min(320px, 90vw);
                    box-shadow: 0 8px 28px rgba(0,0,0,.25); }
    .grille-jour-date { font-size: .8rem; font-weight: 600; color: #333; }
    .grille-jour-responsable { font-size: .78rem; font-weight: 600; color: #222; }
    .nom-tronque { display: block; max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .grille-jour-slots { display: flex; flex-direction: column; gap: 3px; }
    .grille-slot { border-radius: 3px; padding: 2px 4px; font-size: .72rem; color: #fff; display: flex; flex-direction: column; line-height: 1.1; }
    .grille-slot-libelle { font-weight: 600; }
    .grille-slot-horaire { opacity: .9; }
</style>
