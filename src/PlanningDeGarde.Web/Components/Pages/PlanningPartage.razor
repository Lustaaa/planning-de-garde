@page "/planning"
@implements IAsyncDisposable
@inject HttpClient Canal
@inject SessionPlanning Session
@inject NavigationManager Nav
@inject IDateTimeProvider Horloge
@inject OptionsConnexionHub OptionsHub

<PageTitle>Planning partagé</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="m-0">Planning partagé du foyer</h1>
    <div class="d-flex align-items-center gap-3">
        @* Sélecteur d'incarnation (impersonation bornée, lecture seule — sprint 14) : COMPLÈTE le
           sélecteur de rôle démo sans le remplacer (préserve la consultation Invité existante). Incarner
           un acteur reflète son rôle dans la vue (bandeau + menu clic-case selon le type, règle 8) ; la
           valeur vide revient à l'identité réelle (Sc.2). Classe propre (PAS form-select) pour rester
           distinct du sélecteur de rôle. *@
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted">Incarner :</span>
            <select class="selecteur-incarnation form-select-sm w-auto" data-testid="selecteur-incarnation"
                    @bind="IncarnationSelectionnee" @bind:after="StateHasChanged">
                <option value="">— Moi (identité réelle) —</option>
                @foreach (var acteur in Session.ActeursIncarnables)
                {
                    <option value="@acteur.Id">@acteur.Nom</option>
                }
            </select>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted">Rôle :</span>
            <select class="form-select form-select-sm w-auto" @bind="RoleSelectionne">
                <option value="@RoleAuteur.Parent">Parent</option>
                <option value="@RoleAuteur.Invite">Invité (consultation seule)</option>
            </select>
        </div>
    </div>
</div>

@* Bandeau d'incarnation (sprint 14) : « Vous incarnez X » + retour à l'identité réelle (Sc.2). La vue
   reflète le rôle de l'incarné (menu clic-case visible Parent/Admin, masqué Autre). *@
@if (Session.LibelleBandeau is { } libelleBandeau)
{
    <div class="alert alert-secondary d-flex justify-content-between align-items-center py-2"
         data-testid="bandeau-incarnation" role="status">
        <span>@libelleBandeau</span>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-testid="revenir-identite-reelle"
                @onclick="RevenirIdentiteReelle">Revenir à mon identité</button>
    </div>
}

@if (!Session.EstParent)
{
    <div class="alert alert-info py-2">Vous consultez en lecture seule. Les actions d'édition sont désactivées.</div>
}

@* Avertissement de chevauchement « à part » (Sc.7) : la pose chevauchante est ACCEPTÉE (règle 16),
   l'avertissement s'affiche dans un bandeau hors de la dialog, NON bloquant (refermable). *@
@if (_avertissementChevauchement)
{
    <div class="alert alert-warning alert-dismissible py-2" data-testid="avertissement-chevauchement" role="alert">
        Chevauchement signalé : le créneau posé en recouvre un autre le même jour (accepté, à vérifier).
        <button type="button" class="btn-close" aria-label="Fermer" @onclick="FermerAvertissement"></button>
    </div>
}

@* Accusé « Transfert défini » à part (Sc.1) : feedback transitoire NON bloquant, levé sur le simple
   succès HTTP du canal (aucun rendu en case ni read model neuf — règle 27, panneau cloche hors scope).
   Refermable, mécanisme du bandeau d'avertissement réutilisé. *@
@if (_accuseTransfertDefini)
{
    <div class="alert alert-success alert-dismissible py-2" data-testid="accuse-transfert-defini" role="status">
        Transfert défini.
        <button type="button" class="btn-close" aria-label="Fermer" @onclick="FermerAccuseTransfert"></button>
    </div>
}

@* Accusé « Période supprimée » à part (Sc.6) : feedback transitoire NON bloquant, levé sur le succès
   du canal d'écriture. La case re-résolue (repli surcharge > fond > neutre) provient de la relecture de
   la grille distante, jamais d'une mutation locale. Refermable. *@
@if (_accusePeriodeSupprimee)
{
    <div class="alert alert-success alert-dismissible py-2" data-testid="accuse-periode-supprimee" role="status">
        Période supprimée
        <button type="button" class="btn-close" aria-label="Fermer" @onclick="FermerAccusePeriodeSupprimee"></button>
    </div>
}

@* Accusé « Période modifiée » à part (Sc.7) : feedback transitoire NON bloquant, levé sur le succès du
   canal d'écriture d'édition. La case re-résolue (nouveau responsable, ou repli pour la portion libérée)
   provient de la relecture de la grille distante, jamais d'une mutation locale. Refermable. *@
@if (_accusePeriodeModifiee)
{
    <div class="alert alert-success alert-dismissible py-2" data-testid="accuse-periode-modifiee" role="status">
        Période modifiée
        <button type="button" class="btn-close" aria-label="Fermer" @onclick="FermerAccusePeriodeModifiee"></button>
    </div>
}

@* Échec de navigation (Sc.6) : la re-requête de la date naviguée a échoué (API distante injoignable).
   La fenêtre affichée est conservée (l'ancre a été restaurée) ; le bandeau signale l'échec de façon
   claire, NON bloquante (refermable). Aucune navigation n'est mise en file ni rejouée (règle 28). *@
@if (_echecNavigation)
{
    <div class="alert alert-danger alert-dismissible py-2" data-testid="echec-navigation" role="alert">
        @MessagesEcriture.NavigationInjoignable
        <button type="button" class="btn-close" aria-label="Fermer" @onclick="FermerEchecNavigation"></button>
    </div>
}

@* Palier 7 (referme É12) : toute saisie se fait désormais EN CONTEXTE (clic sur une case → menu
   d'actions → dialog). Plus AUCUN lien-barre ni écran de saisie dédié ne subsiste — y compris pour
   le transfert, désormais 3ᵉ entrée du menu clic-case (Sc.1) et seul chemin de saisie (Sc.5). *@

@* Navigation du calendrier (Sc.1) : décale la fenêtre d'une semaine vers le passé / le futur et
   re-projette (re-requête de l'API distante à la date naviguée). L'état de navigation (ancre + vue)
   vit en session/mémoire ; la grille reste en LECTURE SEULE — la navigation ne fait que re-projeter. *@
<div class="d-flex align-items-center gap-2 mb-3" data-testid="barre-navigation"
     data-mode-plage="@(_modePlage ? "1" : "0")">
    <button type="button" class="btn btn-outline-secondary" data-testid="nav-semaine-precedente"
            @onclick="DemanderSemainePrecedente">&lsaquo; Semaine précédente</button>
    <button type="button" class="btn btn-outline-secondary" data-testid="nav-semaine-suivante"
            @onclick="DemanderSemaineSuivante">Semaine suivante &rsaquo;</button>
    <button type="button" class="btn btn-outline-primary" data-testid="nav-aujourdhui"
            @onclick="DemanderRetourAujourdhui">Aujourd'hui</button>

    @* Sélecteur de vue (Sc.2/Sc.3) : choisit la vue prédéfinie de la fenêtre projetée (Semaine /
       4 semaines glissantes — défaut / Mois). Le changement re-projette en re-requêtant l'API distante
       avec le paramètre de vue (read model `GrilleAgendaQuery` vue/span, backend déjà livré). L'ancre
       lundi est conservée ; la grille reste LECTURE SEULE. Sur échec de la re-requête, la vue est
       restaurée et le bandeau d'échec levé (même pivot que la navigation, Sc.6). *@
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted">Vue :</span>
        <select class="form-select form-select-sm w-auto" data-testid="selecteur-vue"
                value="@CodeVue(Session.Vue)" @onchange="ChangerVueAsync">
            <option value="semaine">Semaine</option>
            <option value="4semaines">4 semaines glissantes</option>
            <option value="mois">Mois</option>
        </select>
    </div>

    @* Sélection de plage (Sc.5) : déclencheur d'écriture par INTERVALLE, gardé EstParent (gating règle 9
       mutualisé avec le menu clic-case — c'est ce gate partagé que Sc.7 caractérise : l'Invité ne voit même
       pas ce bouton). Une fois actif, cliquer la case de début puis la case de fin ouvre l'affectation
       pré-remplie sur l'intervalle. La grille reste lecture seule : le mode ne fait que sélectionner. *@
    @if (Session.EstParent)
    {
        <button type="button" class="btn @(_modePlage ? "btn-primary" : "btn-outline-primary") ms-auto"
                data-testid="mode-plage" @onclick="BasculerModePlage">
            @(_modePlage ? "Annuler la sélection de plage" : "Sélectionner une plage")
        </button>
    }
</div>

@if (_modePlage)
{
    <div class="alert alert-info py-2" data-testid="indice-mode-plage" role="status">
        @(_plageDebut is null
            ? "Sélection de plage : cliquez la première case, puis la dernière."
            : "Sélection de plage : cliquez la dernière case de l'intervalle.")
    </div>
}

<section class="grille-agenda" data-testid="grille-agenda">
    <div class="grille-entete">
        @foreach (var jour in JoursDeLaSemaine)
        {
            <div class="grille-entete-jour">@jour</div>
        }
    </div>

    @foreach (var semaine in _grille.Semaines)
    {
        <div class="grille-semaine">
            @foreach (var jourCase in semaine.Jours)
            {
                <div class="grille-jour @(Session.EstParent ? "grille-jour-cliquable" : null) @(EstDansSelectionPlage(jourCase.Date) ? "grille-jour-selectionnee" : null)"
                     data-testid="jour-case"
                     data-couleur="@jourCase.CouleurResponsable"
                     style="background-color:@Teinte(jourCase.CouleurResponsable);"
                     @onclick="@(() => OuvrirMenu(jourCase.Date))">
                    <div class="grille-jour-date">@jourCase.Date.ToString("dd/MM")</div>
                    @if (!string.IsNullOrEmpty(jourCase.NomResponsable))
                    {
                        @* Lisibilité du nom long (Sc.6) : troncature visuelle (CSS) dans la case, nom
                           complet accessible au survol (title). La donnée reste intègre (texte complet). *@
                        <div class="grille-jour-responsable nom-tronque" data-testid="nom-responsable"
                             title="@jourCase.NomResponsable">@jourCase.NomResponsable</div>
                    }
                    <div class="grille-jour-slots">
                        @foreach (var slot in jourCase.Slots)
                        {
                            <div class="grille-slot" data-testid="slot-case"
                                 style="background-color:@Couleur(slot.CouleurActeur);">
                                <span class="grille-slot-libelle">@slot.Libelle</span>
                                <span class="grille-slot-horaire">@slot.Debut.ToString("HH:mm")–@slot.Fin.ToString("HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</section>

<Legende Entrees="_grille.Légende" />

@* Menu d'actions de la case (décision CP, palier 7) : un seul déclencheur d'écriture par case
   (mutualise le gating Invité, Sc.6), deux entrées ouvrant chacune sa dialog pré-remplie sur la
   date de la case. La grille reste en lecture seule : le menu n'écrit jamais. *@
@if (_dateMenu is { } dateMenu)
{
    <div class="menu-backdrop" data-testid="menu-actions-case" @onclick="FermerMenu">
        <div class="menu-panneau" @onclick:stopPropagation="true">
            <h2 class="h6 mb-3">@dateMenu.ToString("dd/MM/yyyy")</h2>
            <button type="button" class="btn btn-outline-primary w-100 mb-2" data-testid="action-poser-slot"
                    @onclick="@(() => OuvrirPoserSlot(dateMenu))">Poser un slot</button>
            <button type="button" class="btn btn-outline-primary w-100 mb-2" data-testid="action-affecter-periode"
                    @onclick="@(() => OuvrirAffecterPeriode(dateMenu))">Affecter une période</button>
            <button type="button" class="btn btn-outline-primary w-100 mb-2" data-testid="action-definir-transfert"
                    @onclick="@(() => OuvrirDefinirTransfert(dateMenu))">Définir un transfert</button>
            <button type="button" class="btn btn-outline-primary w-100 mb-2" data-testid="action-editer-periode"
                    @onclick="@(() => OuvrirEditerPeriode(dateMenu))">Éditer une période</button>
            <button type="button" class="btn btn-outline-danger w-100" data-testid="action-supprimer-periode"
                    @onclick="@(() => OuvrirSupprimerPeriode(dateMenu))">Supprimer une période</button>
        </div>
    </div>
}

@if (_dateDialogPoserSlot is { } datePoserSlot)
{
    <PoserSlotDialog DateContexte="datePoserSlot"
                     OnValide="FermerPoserSlotEtRecharger"
                     OnAnnule="FermerDialog" />
}

@if (_dateDialogAffecterPeriode is { } dateAffecter)
{
    <AffecterPeriodeDialog DateContexte="dateAffecter"
                           DateFinContexte="_plageFin"
                           OnValide="FermerDialogEtRecharger"
                           OnAnnule="FermerDialog" />
}

@if (_dateDialogDefinirTransfert is { } dateTransfert)
{
    <DefinirTransfertDialog DateContexte="dateTransfert"
                            OnValide="FermerTransfertEtAccuser"
                            OnAnnule="FermerDialog" />
}

@if (_dateDialogSupprimerPeriode is { } dateSupprimer)
{
    <SupprimerPeriodeDialog DateContexte="dateSupprimer"
                            OnValide="FermerSuppressionEtAccuser"
                            OnAnnule="FermerDialog" />
}

@if (_dateDialogEditerPeriode is { } dateEditer)
{
    <EditerPeriodeDialog DateContexte="dateEditer"
                         OnValide="FermerEditionEtAccuser"
                         OnAnnule="FermerDialog" />
}

<style>
    .grille-agenda { display: flex; flex-direction: column; gap: 4px; }
    .grille-entete, .grille-semaine { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
    .grille-entete-jour { font-weight: 600; text-align: center; color: #555; padding: 2px 0; }
    .grille-jour { min-height: 90px; border: 1px solid #dee2e6; border-radius: 4px; padding: 4px; display: flex; flex-direction: column; gap: 4px; }
    .grille-jour-cliquable { cursor: pointer; }
    .grille-jour-selectionnee { outline: 3px solid #0d6efd; outline-offset: -3px; }
    .menu-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.3); display: flex;
                     align-items: center; justify-content: center; z-index: 1040; }
    .menu-panneau { background: #fff; border-radius: 6px; padding: 16px; width: min(320px, 90vw);
                    box-shadow: 0 8px 28px rgba(0,0,0,.25); }
    .grille-jour-date { font-size: .8rem; font-weight: 600; color: #333; }
    .grille-jour-responsable { font-size: .78rem; font-weight: 600; color: #222; }
    .nom-tronque { display: block; max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .grille-jour-slots { display: flex; flex-direction: column; gap: 3px; }
    .grille-slot { border-radius: 3px; padding: 2px 4px; font-size: .72rem; color: #fff; display: flex; flex-direction: column; line-height: 1.1; }
    .grille-slot-libelle { font-weight: 600; }
    .grille-slot-horaire { opacity: .9; }
</style>
