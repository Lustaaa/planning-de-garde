@page "/planning/affecter-periode"
@inject AffecterPeriodeHandler Handler
@inject SessionPlanning Session
@inject NavigationManager Nav

<PageTitle>Affecter une période</PageTitle>

<h1 class="h3 mb-3">Affecter la responsabilité d'une période de garde</h1>

@if (!Session.EstParent)
{
    <div class="alert alert-warning">Action réservée aux Parents. Vous êtes en consultation seule.</div>
}
else
{
    <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="affecter-periode">
        <div class="mb-3">
            <label class="form-label">Responsable</label>
            <InputSelect class="form-select" @bind-Value="_form.ResponsableId">
                <option value="">— choisir —</option>
                @foreach (var r in Foyer.Responsables)
                {
                    <option value="@r">@r</option>
                }
            </InputSelect>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label class="form-label">Début</label>
                <InputDate class="form-control" @bind-Value="_form.Debut" />
            </div>
            <div class="col mb-3">
                <label class="form-label">Fin</label>
                <InputDate class="form-control" @bind-Value="_form.Fin" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Affecter</button>
        <a href="planning" class="btn btn-link">Retour au planning</a>
    </EditForm>
}

@if (_motifEchec is not null)
{
    <div class="alert alert-danger mt-3" data-testid="motif-echec">@_motifEchec</div>
}

@code {
    private sealed class Formulaire
    {
        public string ResponsableId { get; set; } = "";
        public DateTime Debut { get; set; } = new(2025, 7, 14);
        public DateTime Fin { get; set; } = new(2025, 7, 21);
    }

    private readonly Formulaire _form = new();
    private string? _motifEchec;

    private void Soumettre()
    {
        _motifEchec = null;
        var resultat = Handler.Handle(
            new AffecterPeriodeCommand(_form.ResponsableId, _form.Debut, _form.Fin));

        if (resultat.EstSucces)
            Nav.NavigateTo("planning");
        else
            _motifEchec = resultat.Motif;
    }
}
