@inject HttpClient Canal
@inject SessionPlanning Session

@* Dialog (modal) « Poser un slot récurrent » (s29, S8), déclenchée depuis une case du planning (menu
   clic-case, écriture en contexte). Le formulaire émet sa commande via le canal d'écriture HTTP
   (POST /api/canal/poser-slot-recurrent) — aucune règle métier dans l'UI. Le jour de semaine est
   pré-rempli sur celui de la case cliquée (« chez papa tous les samedis » → cliquer un samedi). Issues :
   succès → OnValide (le parent ferme et relit la grille, les occurrences apparaissent) ; refus domaine
   (lieu inconnu / durée non positive) ou API injoignable → message DANS la dialog, saisie conservée. *@
<div class="dialog-backdrop" data-testid="dialog-poser-slot-recurrent">
    <div class="dialog-panneau">
        <h2 class="h4 mb-3">Poser un slot récurrent</h2>
        <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="poser-slot-recurrent-dialog">
            <div class="mb-3">
                <label class="form-label">Enfant</label>
                <input class="form-control" value="@Session.EnfantId" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">Lieu</label>
                <InputSelect class="form-select" data-testid="champ-lieu-recurrent" @bind-Value="_form.LieuId">
                    <option value="">— choisir —</option>
                    @foreach (var lieu in Lieux)
                    {
                        <option value="@lieu.Id">@lieu.Libelle</option>
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label class="form-label">Jour de la semaine</label>
                <InputSelect class="form-select" data-testid="champ-jour-recurrent" @bind-Value="_form.Jour">
                    @foreach (var jour in JoursDeLaSemaine)
                    {
                        <option value="@jour">@LibelleJour(jour)</option>
                    }
                </InputSelect>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label class="form-label">Début</label>
                    <InputDate Type="InputDateType.Time" class="form-control" data-testid="champ-heure-debut-recurrent" @bind-Value="_form.Debut" />
                </div>
                <div class="col mb-3">
                    <label class="form-label">Fin</label>
                    <InputDate Type="InputDateType.Time" class="form-control" data-testid="champ-heure-fin-recurrent" @bind-Value="_form.Fin" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Poser le slot récurrent</button>
                <button type="button" class="btn btn-link" data-testid="dialog-annuler-recurrent" @onclick="Annuler">Annuler</button>
            </div>
        </EditForm>

        @if (_motifEchec is not null)
        {
            <div class="alert alert-danger mt-3" data-testid="motif-echec-recurrent">@_motifEchec</div>
        }
    </div>
</div>
