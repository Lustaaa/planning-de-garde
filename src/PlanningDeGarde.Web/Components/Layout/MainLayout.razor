@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="pdg-domaine">Le planning de garde des enfants du foyer</span>
            @* Menu utilisateur connecté (Sc.11) : nom / acteur + accès config + Se déconnecter, une fois
               une session ouverte (page de connexion dédiée, Sc.8). Présent sur toutes les pages. *@
            <MenuUtilisateur />
            @* Switch de thème clair/sombre (Sc.3) : visible dans le layout sur toutes les pages,
               persiste le choix (localStorage, prioritaire sur le système) et l'applique sans rechargement. *@
            <BasculeTheme />
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">À propos</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
