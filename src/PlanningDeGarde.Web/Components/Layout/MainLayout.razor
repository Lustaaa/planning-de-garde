@inherits LayoutComponentBase

<div class="page">
    @* Barre d'application unique (refonte nav hors-sprint) : plus de barre latérale — 2 destinations
       seulement. La marque ramène au planning ; la navigation primaire et les actions (identité, thème)
       tiennent sur une seule ligne, ce qui rend le calendrier (héros) pleine largeur et simplifie iOS. *@
    <header class="app-bar">
        <a class="app-brand" href="planning">
            <span class="app-brand-pastille" aria-hidden="true"></span>
            <span class="pdg-brand-titre">Planning du foyer</span>
        </a>

        <NavMenu />

        <div class="app-bar-actions">
            @* Menu utilisateur : identité + accès Foyer + Se déconnecter, une fois connecté (sinon rien). *@
            <MenuUtilisateur />
            @* Bascule de thème clair/sombre : persiste le choix (localStorage), applique sans rechargement. *@
            <BasculeTheme />
        </div>
    </header>

    <main class="app-main">
        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Une erreur inattendue s'est produite.
    <a href="." class="reload">Recharger</a>
    <span class="dismiss">🗙</span>
</div>
