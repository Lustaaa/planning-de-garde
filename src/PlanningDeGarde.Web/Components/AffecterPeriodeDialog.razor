@inject HttpClient Canal

@* Dialog (modal) « Affecter une période » réutilisable, ouverte depuis le menu d'actions d'une case
   du planning (palier 7, écriture en contexte). Le formulaire est extrait de la page AffecterPeriode ;
   il émet sa commande via le MÊME canal d'écriture HTTP (POST /api/canal/affecter-periode) — aucune
   règle métier dans l'UI. La date de contexte (case cliquée) pré-remplit la saisie sur ce seul jour.
   Issues : succès → OnValide (le parent ferme et relit la grille) ; refus domaine / API injoignable →
   message DANS la dialog, saisie conservée. Le sélecteur affiche le libellé mais bind l'id stable. *@
<div class="dialog-backdrop" data-testid="dialog-affecter-periode">
    <div class="dialog-panneau">
        <h2 class="h4 mb-3">Affecter une période</h2>
        <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="affecter-periode-dialog">
            <div class="mb-3">
                <label class="form-label">Responsable</label>
                <InputSelect class="form-select" data-testid="champ-responsable" @bind-Value="_form.ResponsableId">
                    <option value="">— choisir —</option>
                    @foreach (var a in Acteurs)
                    {
                        <option value="@a.Id">@a.Nom</option>
                    }
                </InputSelect>
                @if (ActeursCharges && Acteurs.Count == 0)
                {
                    <div class="form-text text-warning" data-testid="aucun-acteur-invite">Aucun acteur, ajoutez-en.</div>
                }
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label class="form-label">Début</label>
                    <InputDate class="form-control" @bind-Value="_form.Debut" />
                </div>
                <div class="col mb-3">
                    <label class="form-label">Fin</label>
                    <InputDate class="form-control" @bind-Value="_form.Fin" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Affecter</button>
                <button type="button" class="btn btn-link" data-testid="dialog-annuler" @onclick="Annuler">Annuler</button>
            </div>
        </EditForm>

        @if (_motifEchec is not null)
        {
            <div class="alert alert-danger mt-3" data-testid="motif-echec">@_motifEchec</div>
        }
    </div>
</div>
