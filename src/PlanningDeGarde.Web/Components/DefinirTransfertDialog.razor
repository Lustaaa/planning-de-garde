@inject HttpClient Canal

@* Dialog (modal) « Définir un transfert » réutilisable, ouverte depuis le menu d'actions d'une case
   du planning (palier 7, écriture en contexte — 3e dialog qui referme l'épic É12). Le formulaire est
   extrait de la page DefinirTransfert ; il émet sa commande via le MÊME canal d'écriture HTTP
   (POST /api/transferts) — aucune règle métier dans l'UI. La date de contexte (case
   cliquée) pré-remplit la saisie sur ce seul jour. Issues : succès → OnValide (le parent ferme la
   dialog, l'accusé « Transfert défini » s'affiche à part) ; refus domaine / API injoignable → message
   DANS la dialog, saisie conservée. Les sélecteurs dépose/récupère bindent l'identifiant stable
   (parent-a / parent-b), jamais le libellé (règle 19). *@
<div class="dialog-backdrop" data-testid="dialog-definir-transfert">
    <div class="dialog-panneau">
        <h2 class="h4 mb-3">Définir un transfert</h2>
        @* Enfant COURANT hérité du sélecteur de vue (s53, Option A) : affiché en LECTURE SEULE — le transfert
           saisi est scopé à l'enfant de la vue (gate G3 : plus de fuite « Mia » → « Charlie »). *@
        <p class="text-muted small mb-3" data-testid="definir-transfert-enfant-courant">Pour : @EnfantNom (sélection courante)</p>
        <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="definir-transfert-dialog">
            <div class="row">
                <div class="col mb-3">
                    <label class="form-label">Dépose par</label>
                    <InputSelect class="form-select" data-testid="champ-depose" @bind-Value="_form.DeposeParId">
                        <option value="">— choisir —</option>
                        @foreach (var a in Acteurs)
                        {
                            <option value="@a.Id">@a.Nom</option>
                        }
                    </InputSelect>
                </div>
                <div class="col mb-3">
                    <label class="form-label">Récupère par</label>
                    <InputSelect class="form-select" data-testid="champ-recupere" @bind-Value="_form.RecupereParId">
                        <option value="">— choisir —</option>
                        @foreach (var a in Acteurs)
                        {
                            <option value="@a.Id">@a.Nom</option>
                        }
                    </InputSelect>
                </div>
            </div>
            @if (ActeursCharges && Acteurs.Count == 0)
            {
                <div class="alert alert-warning py-2" data-testid="aucun-acteur-invite">Aucun acteur, ajoutez-en.</div>
            }
            <div class="row">
                <div class="col mb-3">
                    <label class="form-label">Lieu</label>
                    <InputSelect class="form-select" data-testid="champ-lieu" @bind-Value="_form.LieuId">
                        <option value="">— choisir —</option>
                        @foreach (var lieu in Lieux)
                        {
                            <option value="@lieu.Id">@lieu.Libelle</option>
                        }
                    </InputSelect>
                </div>
                <div class="col mb-3">
                    <label class="form-label">Date</label>
                    <InputDate class="form-control" data-testid="champ-date" @bind-Value="_form.Date" />
                </div>
                <div class="col mb-3">
                    <label class="form-label">Heure</label>
                    <input type="time" class="form-control" data-testid="champ-heure" @bind="_heure" @bind:format="HH:mm" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Définir le transfert</button>
                <button type="button" class="btn btn-link" data-testid="dialog-annuler" @onclick="Annuler">Annuler</button>
            </div>
        </EditForm>

        @if (_motifEchec is not null)
        {
            <div class="alert alert-danger mt-3" data-testid="motif-echec">@_motifEchec</div>
        }
    </div>
</div>
