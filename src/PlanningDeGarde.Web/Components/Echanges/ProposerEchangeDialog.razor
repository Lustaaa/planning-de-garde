@inject HttpClient Canal

@* Mini-dialog « Proposer un échange » (s47) ouverte depuis l'entrée « proposer un échange » du menu clic-case
   (Parent-gated : le menu ne s'ouvre que pour un Parent). « Je ne peux pas récupérer ce jour, échange-le avec
   moi » : on choisit l'acteur RECEVANT ; valider émet la commande via le CANAL D'ÉCRITURE
   (POST /api/propositions) — jamais la diffusion. PROPOSER n'écrit AUCUNE surcharge (canal de
   consentement) : la case reste inchangée tant que le recevant n'a pas accepté depuis sa cloche. Portée par
   ModalConfig : Échap = « Annuler » (port IEcouteurEchapModal s33, capture document). Issues : succès →
   OnValide ; refus domaine (recevant inconnu / à soi-même) / API injoignable → MOTIF dans la dialog, saisie
   CONSERVÉE, dialog restée OUVERTE (parité s44 Sc.5). *@
<ModalConfig TestId="dialog-proposer" OnFermer="OnAnnule">
    <h2 class="h4 mb-3">Proposer un échange</h2>
    <p class="text-muted small mb-3">Vous ne pouvez pas récupérer le @DateContexte.ToString("dd/MM/yyyy") — proposez l'échange à un autre acteur, qui décidera d'accepter.</p>
    <EditForm Model="_form" OnValidSubmit="Soumettre" FormName="proposer-echange-dialog">
        <div class="mb-3">
            <label class="form-label">Proposer à</label>
            <InputSelect class="form-select" data-testid="champ-recevant" @bind-Value="_form.VersActeurId">
                <option value="">— choisir —</option>
                @foreach (var a in Acteurs)
                {
                    <option value="@a.Id">@a.Nom</option>
                }
            </InputSelect>
            @if (ActeursCharges && Acteurs.Count == 0)
            {
                <div class="form-text text-warning" data-testid="aucun-acteur-invite">Aucun acteur, ajoutez-en.</div>
            }
        </div>
        @* Champ « jusqu'au » (s52) : date de fin INCLUSE de la plage proposée. Défaut = jour cliqué (fin =
           début) → échange d'UN jour (s47) inchangé. Une seule proposition [début..fin] est émise (miroir s45). *@
        <div class="mb-3">
            <label class="form-label">Jusqu'au</label>
            <InputDate class="form-control" data-testid="champ-jusqu-au" @bind-Value="_form.Jusqu" />
        </div>
        <div class="dialog-actions">
            <button type="submit" class="btn btn-primary">Proposer l'échange</button>
            <button type="button" class="btn btn-link" data-testid="dialog-proposer-annuler" @onclick="Annuler">Annuler</button>
        </div>
    </EditForm>

    @if (_motifEchec is not null)
    {
        <div class="alert alert-danger mt-3" data-testid="motif-echec-proposer">@_motifEchec</div>
    }
</ModalConfig>
