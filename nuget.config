<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Sources NuGet scopées au dépôt. On n'hérite PAS du feed privé CNDO (Azure DevOps GTA),
    inaccessible/expiré hors réseau d'entreprise et dont l'index en échec (401) faisait
    planter la restauration de toute la solution. Ce projet personnel ne tire que de
    nuget.org (+ le cache offline Visual Studio). <clear/> repart d'une liste vide.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="Microsoft Visual Studio Offline Packages" value="C:\Program Files (x86)\Microsoft SDKs\NuGetPackages\" />
  </packageSources>
</configuration>
