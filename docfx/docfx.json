{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "PlanningDeGarde.Web/**"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "net10.0"
      },
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "index.md",
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": []
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "PlanningDeGarde",
      "_appTitle": "PlanningDeGarde — Documentation technique",
      "_enableSearch": true,
      "_disableContribution": true
    },
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
